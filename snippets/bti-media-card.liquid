{%- liquid
  assign bti_image = image
  assign bti_alt = image_alt | default: title
-%}

<article class="bti-media-card">
  {%- if bti_image != blank -%}
    <div class="bti-media-card__media">
      {{
        bti_image
        | image_url: width: 1200
        | image_tag:
          loading: 'lazy',
          widths: '360, 540, 720, 960, 1200',
          sizes: '(min-width: 750px) 50vw, 100vw',
          alt: bti_alt
      }}
    </div>
  {%- endif -%}
  <div class="bti-media-card__body">
    {%- if title != blank -%}
      <h3 class="bti-media-card__title">{{ title | escape }}</h3>
    {%- endif -%}
    {%- if text != blank -%}
      <div class="bti-media-card__text">{{ text }}</div>
    {%- endif -%}
    {%- render 'bti-cta-row',
      primary_label: primary_label,
      primary_url: primary_url,
      secondary_label: secondary_label,
      secondary_url: secondary_url
    -%}
  </div>
</article>

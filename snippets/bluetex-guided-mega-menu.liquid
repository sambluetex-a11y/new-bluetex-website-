<script>
  (() => {
    const nav = document.querySelector('[data-bluetex-guided-nav]');
    if (!nav) return;

    const desktopQuery = window.matchMedia('(min-width: 990px)');
    const menus = Array.from(nav.querySelectorAll('[data-bluetex-guided-menu]'));
    const closeTimers = new WeakMap();

    const closeMenu = (menu) => {
      window.clearTimeout(closeTimers.get(menu));
      menu.classList.remove('is-open');
    };

    const closeOthers = (activeMenu) => {
      menus.forEach((menu) => {
        if (menu !== activeMenu) closeMenu(menu);
      });
    };

    const openMenu = (menu) => {
      if (!desktopQuery.matches) return;
      window.clearTimeout(closeTimers.get(menu));
      closeOthers(menu);
      menu.classList.add('is-open');
    };

    const queueClose = (menu) => {
      if (!desktopQuery.matches) {
        closeMenu(menu);
        return;
      }
      window.clearTimeout(closeTimers.get(menu));
      closeTimers.set(menu, window.setTimeout(() => closeMenu(menu), 180));
    };

    menus.forEach((menu) => {
      const preview = menu.querySelector('[data-bt-mega-preview]');
      const previewImage = preview?.querySelector('[data-bt-mega-preview-image]');
      const previewPlaceholder = preview?.querySelector('[data-bt-mega-preview-placeholder]');
      const previewTitle = preview?.querySelector('[data-bt-mega-preview-title]');
      const previewCaption = preview?.querySelector('[data-bt-mega-preview-caption]');
      const defaultPreview = {
        image: preview?.dataset.defaultImage || '',
        title: preview?.dataset.defaultTitle || '',
        caption: preview?.dataset.defaultCaption || '',
        fit: preview?.dataset.defaultFit || 'contain',
        position: preview?.dataset.defaultPosition || 'center'
      };

      const updatePreview = (link) => {
        if (!preview || !link) return;
        const nextImage = link.dataset.previewImage || defaultPreview.image;
        if (previewImage && nextImage) {
          previewImage.src = nextImage;
          previewImage.style.setProperty('--bt-preview-fit', link.dataset.previewFit || defaultPreview.fit);
          previewImage.style.setProperty('--bt-preview-position', link.dataset.previewPosition || defaultPreview.position);
          previewImage.classList.remove('is-hidden');
          previewPlaceholder?.classList.add('is-hidden');
        } else if (previewImage) {
          previewImage.removeAttribute('src');
          previewImage.classList.add('is-hidden');
          previewPlaceholder?.classList.remove('is-hidden');
        }
        if (previewTitle) previewTitle.textContent = link.dataset.previewTitle || defaultPreview.title;
        if (previewCaption) previewCaption.textContent = link.dataset.previewCaption || defaultPreview.caption;
      };

      const resetPreview = () => {
        if (!preview) return;
        if (previewImage && defaultPreview.image) {
          previewImage.src = defaultPreview.image;
          previewImage.style.setProperty('--bt-preview-fit', defaultPreview.fit);
          previewImage.style.setProperty('--bt-preview-position', defaultPreview.position);
          previewImage.classList.remove('is-hidden');
          previewPlaceholder?.classList.add('is-hidden');
        } else if (previewImage) {
          previewImage.removeAttribute('src');
          previewImage.classList.add('is-hidden');
          previewPlaceholder?.classList.remove('is-hidden');
        }
        if (previewTitle) previewTitle.textContent = defaultPreview.title;
        if (previewCaption) previewCaption.textContent = defaultPreview.caption;
      };

      menu.addEventListener('mouseenter', () => openMenu(menu));
      menu.addEventListener('mouseleave', () => {
        resetPreview();
        queueClose(menu);
      });
      menu.addEventListener('focusin', () => openMenu(menu));
      menu.addEventListener('focusout', () => queueClose(menu));

      menu.querySelectorAll('.bluetex-mega__preview-link').forEach((link) => {
        link.addEventListener('mouseenter', () => updatePreview(link));
        link.addEventListener('focus', () => updatePreview(link));
      });
    });

    nav.addEventListener('keydown', (event) => {
      if (event.key !== 'Escape') return;
      menus.forEach(closeMenu);
    });

    desktopQuery.addEventListener('change', () => {
      menus.forEach(closeMenu);
    });
  })();
</script>

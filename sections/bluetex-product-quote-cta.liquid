<section id="BlueTexProductQuoteCta-{{ section.id }}" class="bt-product-quote">
  <div class="bt-product-quote__inner">
    <div>
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.text }}</p>
    </div>
    <div class="bt-product-quote__actions">
      {%- if section.settings.primary_label != blank -%}<a class="bt-product-quote__btn bt-product-quote__btn--orange" href="{{ section.settings.primary_link }}">{{ section.settings.primary_label }}</a>{%- endif -%}
      {%- if section.settings.secondary_label != blank -%}<a class="bt-product-quote__btn bt-product-quote__btn--white" href="{{ section.settings.secondary_link }}">{{ section.settings.secondary_label }}</a>{%- endif -%}
      {%- if section.settings.tertiary_label != blank -%}<a class="bt-product-quote__btn bt-product-quote__btn--outline" href="{{ section.settings.tertiary_link }}">{{ section.settings.tertiary_label }}</a>{%- endif -%}
    </div>
  </div>
</section>

<style>
  #BlueTexProductQuoteCta-{{ section.id }} { --bt-navy:#0011a7; --bt-orange:#ee7f12; --bt-orange-hov:#3f62c5; font-family:Lato,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif; background:#fff; padding:40px 20px; border-top:1px solid #e6e6e7; }
  #BlueTexProductQuoteCta-{{ section.id }} * { box-sizing:border-box; }
  #BlueTexProductQuoteCta-{{ section.id }} .bt-product-quote__inner { max-width:1140px; margin:0 auto; padding:34px 38px; background:#002f6c; color:#fff; border-left:6px solid var(--bt-navy); border-radius:2px; display:grid; grid-template-columns:1.35fr auto; gap:28px; align-items:center; }
  #BlueTexProductQuoteCta-{{ section.id }} h2 { margin:0 0 8px; color:#fff; font-size:24px; line-height:1.12; font-weight:700; letter-spacing:.2px; text-transform:uppercase; }
  #BlueTexProductQuoteCta-{{ section.id }} p { margin:0; color:#e0e4f0; font-size:15px; line-height:1.55; max-width:680px; }
  #BlueTexProductQuoteCta-{{ section.id }} .bt-product-quote__actions { display:flex; gap:10px; flex-wrap:wrap; justify-content:flex-end; }
  #BlueTexProductQuoteCta-{{ section.id }} .bt-product-quote__btn { display:inline-flex; align-items:center; justify-content:center; padding:14px 22px; border-radius:4px; border:2px solid transparent; font-size:13px; font-weight:700; letter-spacing:.8px; text-transform:uppercase; text-decoration:none; white-space:nowrap; }
  #BlueTexProductQuoteCta-{{ section.id }} .bt-product-quote__btn--orange { background:var(--bt-navy); color:#fff; border-color:var(--bt-navy); }
  #BlueTexProductQuoteCta-{{ section.id }} .bt-product-quote__btn--orange:hover { background:var(--bt-navy-hov); border-color:var(--bt-navy-hov); }
  #BlueTexProductQuoteCta-{{ section.id }} .bt-product-quote__btn--white { background:#fff; color:var(--bt-navy); border-color:#fff; }
  #BlueTexProductQuoteCta-{{ section.id }} .bt-product-quote__btn--outline { background:transparent; color:#fff; border-color:#fff; }
  @media (max-width: 900px) { #BlueTexProductQuoteCta-{{ section.id }} .bt-product-quote__inner { grid-template-columns:1fr; padding:30px 28px; } #BlueTexProductQuoteCta-{{ section.id }} .bt-product-quote__actions { justify-content:flex-start; } }
  @media (max-width: 560px) { #BlueTexProductQuoteCta-{{ section.id }} { padding:32px 16px; } #BlueTexProductQuoteCta-{{ section.id }} .bt-product-quote__inner { padding:28px 22px; } #BlueTexProductQuoteCta-{{ section.id }} .bt-product-quote__btn { width:100%; } }
</style>

{% schema %}
{
  "name": "BlueTex Product Quote CTA",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Ready for a Full-Building Material List?" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Send photos and rough dimensions of the building. We put together a material list and quote faster when we can see what you're working with, and your $100 sample-box credit goes toward the order." },
    { "type": "text", "id": "primary_label", "label": "Primary label", "default": "Request a Quote" },
    { "type": "url", "id": "primary_link", "label": "Primary link" },
    { "type": "text", "id": "secondary_label", "label": "Secondary label", "default": "Send Photos for a Quote" },
    { "type": "url", "id": "secondary_link", "label": "Secondary link" },
    { "type": "text", "id": "tertiary_label", "label": "Tertiary label", "default": "Get a Full-Building Material List" },
    { "type": "url", "id": "tertiary_link", "label": "Tertiary link" }
  ],
  "presets": [
    { "name": "BlueTex Product Quote CTA" }
  ]
}
{% endschema %}

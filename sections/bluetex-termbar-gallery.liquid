<section id="BlueTexTermbarGallery-{{ section.id }}" class="bt-tbgallery">
  <div class="bt-tbgallery__wrap">
    <div class="bt-tbgallery__head">
      {%- if section.settings.eyebrow != blank -%}
        <span class="bt-tbgallery__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2>{{ section.settings.heading }}</h2>
      {%- if section.settings.text != blank -%}
        <p>{{ section.settings.text }}</p>
      {%- endif -%}
    </div>
    {%- if section.blocks.size > 0 -%}
      <div class="bt-tbgallery__grid">
        {%- for block in section.blocks -%}
          <article class="bt-tbgallery__card" {{ block.shopify_attributes }}>
            <div class="bt-tbgallery__pair">
              <div class="bt-tbgallery__cell">
                <span class="bt-tbgallery__tag bt-tbgallery__tag--before">Before</span>
                {%- if block.settings.before_image != blank -%}
                  {{ block.settings.before_image | image_url: width: 1200 | image_tag: loading: 'lazy', widths: '500, 800, 1100, 1200', sizes: '(min-width: 990px) 33vw, 50vw', alt: block.settings.before_alt }}
                {%- else -%}
                  <span class="bt-tbgallery__placeholder">Add before photo</span>
                {%- endif -%}
              </div>
              <div class="bt-tbgallery__cell">
                <span class="bt-tbgallery__tag bt-tbgallery__tag--after">After</span>
                {%- if block.settings.after_image != blank -%}
                  {{ block.settings.after_image | image_url: width: 1200 | image_tag: loading: 'lazy', widths: '500, 800, 1100, 1200', sizes: '(min-width: 990px) 33vw, 50vw', alt: block.settings.after_alt }}
                {%- else -%}
                  <span class="bt-tbgallery__placeholder">Add after photo</span>
                {%- endif -%}
              </div>
            </div>
            {%- if block.settings.caption != blank -%}
              <p class="bt-tbgallery__caption">{{ block.settings.caption }}</p>
            {%- endif -%}
          </article>
        {%- endfor -%}
      </div>
    {%- else -%}
      <div class="bt-tbgallery__empty">
        Add before and after photo blocks to populate this gallery.
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  #BlueTexTermbarGallery-{{ section.id }} { --bt-navy:#0011a7; --bt-deep:#002f6c; --bt-orange:#ee7f12; --bt-text:#1b1b1b; --bt-muted:#535254; --bt-soft:#e6e6e7; font-family:Lato,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif; background:#fff; padding:56px 20px; border-top:1px solid var(--bt-soft); }
  #BlueTexTermbarGallery-{{ section.id }} * { box-sizing:border-box; }
  #BlueTexTermbarGallery-{{ section.id }} .bt-tbgallery__wrap { max-width:1140px; margin:0 auto; }
  #BlueTexTermbarGallery-{{ section.id }} .bt-tbgallery__head { max-width:760px; margin:0 auto 28px; text-align:center; }
  #BlueTexTermbarGallery-{{ section.id }} .bt-tbgallery__eyebrow { display:inline-block; background:var(--bt-orange); color:#fff; font-size:11px; font-weight:700; letter-spacing:1.6px; text-transform:uppercase; padding:5px 12px; border-radius:2px; margin-bottom:12px; }
  #BlueTexTermbarGallery-{{ section.id }} h2 { margin:0 0 10px; color:var(--bt-navy); font-size:28px; line-height:1.12; font-weight:700; letter-spacing:.2px; text-transform:uppercase; }
  #BlueTexTermbarGallery-{{ section.id }} .bt-tbgallery__head p { margin:0; color:var(--bt-text); font-size:15px; line-height:1.55; }
  #BlueTexTermbarGallery-{{ section.id }} .bt-tbgallery__grid { display:grid; grid-template-columns:1fr; gap:20px; }
  #BlueTexTermbarGallery-{{ section.id }} .bt-tbgallery__card { border:1px solid var(--bt-soft); border-radius:6px; overflow:hidden; background:#fff; }
  #BlueTexTermbarGallery-{{ section.id }} .bt-tbgallery__pair { display:grid; grid-template-columns:1fr 1fr; gap:1px; background:var(--bt-soft); }
  #BlueTexTermbarGallery-{{ section.id }} .bt-tbgallery__cell { position:relative; aspect-ratio:4/3; background:#002f6c; overflow:hidden; }
  #BlueTexTermbarGallery-{{ section.id }} .bt-tbgallery__cell img { width:100%; height:100%; object-fit:cover; display:block; }
  #BlueTexTermbarGallery-{{ section.id }} .bt-tbgallery__placeholder { position:absolute; inset:0; display:flex; align-items:center; justify-content:center; color:#fff; font-size:12px; font-weight:700; letter-spacing:1.4px; text-transform:uppercase; border:1px dashed rgba(255,255,255,.35); background:#002f6c; }
  #BlueTexTermbarGallery-{{ section.id }} .bt-tbgallery__tag { position:absolute; top:14px; z-index:2; color:#fff; padding:5px 12px; border-radius:2px; font-size:11px; font-weight:700; letter-spacing:1.6px; text-transform:uppercase; }
  #BlueTexTermbarGallery-{{ section.id }} .bt-tbgallery__tag--before { left:14px; background:var(--bt-navy); }
  #BlueTexTermbarGallery-{{ section.id }} .bt-tbgallery__tag--after { left:14px; background:var(--bt-orange); }
  #BlueTexTermbarGallery-{{ section.id }} .bt-tbgallery__caption { margin:0; padding:14px 18px; color:var(--bt-deep); font-size:13px; font-weight:700; letter-spacing:.6px; text-transform:uppercase; border-top:1px solid var(--bt-soft); background:#fff; }
  #BlueTexTermbarGallery-{{ section.id }} .bt-tbgallery__empty { padding:40px; border:1px dashed var(--bt-soft); border-radius:6px; text-align:center; color:var(--bt-muted); font-size:13px; font-weight:700; letter-spacing:1px; text-transform:uppercase; }
  @media (min-width: 860px) { #BlueTexTermbarGallery-{{ section.id }} .bt-tbgallery__grid { grid-template-columns:repeat(2,1fr); } }
  @media (max-width: 560px) { #BlueTexTermbarGallery-{{ section.id }} { padding:40px 16px; } #BlueTexTermbarGallery-{{ section.id }} h2 { font-size:22px; } #BlueTexTermbarGallery-{{ section.id }} .bt-tbgallery__pair { grid-template-columns:1fr; } }
</style>

{% schema %}
{
  "name": "BlueTex TermBar Gallery",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Real Buildings" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Before and After in the Field" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "A few examples of what BlueTex looks like going over old insulation in the buildings we work with every week." }
  ],
  "blocks": [
    {
      "type": "pair",
      "name": "Before / After Pair",
      "settings": [
        { "type": "image_picker", "id": "before_image", "label": "Before image" },
        { "type": "text", "id": "before_alt", "label": "Before image alt", "default": "Old torn metal building insulation before BlueTex" },
        { "type": "image_picker", "id": "after_image", "label": "After image" },
        { "type": "text", "id": "after_alt", "label": "After image alt", "default": "Finished BlueTex install with TermBars" },
        { "type": "text", "id": "caption", "label": "Caption" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "BlueTex TermBar Gallery",
      "blocks": [
        { "type": "pair", "settings": { "caption": "Add a building name or location" } },
        { "type": "pair", "settings": { "caption": "Add a building name or location" } },
        { "type": "pair", "settings": { "caption": "Add a building name or location" } }
      ]
    }
  ]
}
{% endschema %}

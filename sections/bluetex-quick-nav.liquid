<section id="BlueTexQuickNav-{{ section.id }}" class="bt-quick-nav">
  <div class="bt-quick-nav__grid">
    {%- for block in section.blocks -%}
      <a class="bt-quick-nav__item" href="{{ block.settings.link }}" {{ block.shopify_attributes }}>
        <span>{{ block.settings.label }}</span>
        <span class="bt-quick-nav__arrow">›</span>
      </a>
    {%- endfor -%}
  </div>
</section>

<style>
  #BlueTexQuickNav-{{ section.id }} { --bt-navy:#0011a7; --bt-navy-hov:#3f62c5; --bt-deep:#002f6c; --bt-orange:#ee7f12; font-family:Lato,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif; background:#fff; padding:18px 0 6px; }
  #BlueTexQuickNav-{{ section.id }} * { box-sizing:border-box; }
  #BlueTexQuickNav-{{ section.id }} .bt-quick-nav__grid { max-width:1140px; margin:0 auto; padding:0 20px; display:grid; grid-template-columns:repeat(4,1fr); gap:4px; }
  #BlueTexQuickNav-{{ section.id }} .bt-quick-nav__item { min-height:76px; background:var(--bt-deep); color:#fff; border-radius:2px; border-bottom:3px solid var(--bt-navy); padding:18px 20px; display:flex; align-items:center; justify-content:space-between; gap:12px; text-decoration:none; font-size:13px; font-weight:700; letter-spacing:.8px; line-height:1.2; text-transform:uppercase; }
  #BlueTexQuickNav-{{ section.id }} .bt-quick-nav__item:hover { background:var(--bt-navy-hov); text-decoration:none; }
  #BlueTexQuickNav-{{ section.id }} .bt-quick-nav__arrow { color:var(--bt-orange); font-size:24px; font-weight:700; }
  @media (max-width: 900px) { #BlueTexQuickNav-{{ section.id }} .bt-quick-nav__grid { grid-template-columns:repeat(2,1fr); } }
  @media (max-width: 560px) { #BlueTexQuickNav-{{ section.id }} .bt-quick-nav__grid { grid-template-columns:1fr; padding:0 16px; } }
</style>

{% schema %}
{
  "name": "BlueTex Quick Nav",
  "settings": [],
  "blocks": [
    {
      "type": "link",
      "name": "Navigation block",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Wall Cover & Repair" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "BlueTex Quick Nav",
      "blocks": [
        { "type": "link", "settings": { "label": "Wall Cover & Repair" } },
        { "type": "link", "settings": { "label": "Roof Cover & Repair" } },
        { "type": "link", "settings": { "label": "Metal Building Retrofit" } },
        { "type": "link", "settings": { "label": "Roll-Up Doors" } }
      ]
    }
  ]
}
{% endschema %}

{%- liquid
  assign hero_heading = section.settings.heading | default: 'Repair Old or Torn Insulation — Without Tearing It Out'
  assign hero_label_1 = section.settings.sub_label_1 | default: 'Tear-Proof / Puncture-Resistant'
  assign hero_label_2 = section.settings.sub_label_2 | default: 'Internal Vapor Barrier Replacement System'
  assign media_alt = section.settings.image_alt | default: hero_heading
  assign resolved_video_url = section.settings.video_url
  if section.settings.video_asset_filename != blank
    assign resolved_video_url = section.settings.video_asset_filename | asset_url
  endif
-%}

<section class="btx-hero" aria-labelledby="btx-hero-heading-{{ section.id }}">
  <div class="btx-hero__media">
    {%- if section.settings.media_type == 'video' and resolved_video_url != blank -%}
      <video
        class="btx-hero__video"
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        aria-label="{{ media_alt | escape }}"
        {% if section.settings.poster != blank %}poster="{{ section.settings.poster | image_url: width: 1800 }}"{% endif %}
      >
        <source src="{{ resolved_video_url }}" type="video/mp4">
      </video>
    {%- elsif section.settings.image != blank -%}
      {{
        section.settings.image
        | image_url: width: 2400
        | image_tag:
          class: 'btx-hero__img',
          loading: 'eager',
          widths: '720, 1080, 1440, 1800, 2200',
          sizes: '100vw',
          alt: media_alt
      }}
    {%- elsif section.settings.poster != blank -%}
      {{
        section.settings.poster
        | image_url: width: 2400
        | image_tag:
          class: 'btx-hero__img',
          loading: 'eager',
          widths: '720, 1080, 1440, 1800, 2200',
          sizes: '100vw',
          alt: media_alt
      }}
    {%- endif -%}
    <div class="btx-hero__scrim" aria-hidden="true"></div>
  </div>

  <div class="btx-hero__overlay">
    <div class="btx-hero__inner">
      {%- if section.settings.kicker != blank -%}
        <p class="btx-hero__kicker">{{ section.settings.kicker | escape }}</p>
      {%- endif -%}
      <h1 id="btx-hero-heading-{{ section.id }}" class="btx-hero__heading">{{ hero_heading | escape }}</h1>
      <ul class="btx-hero__pills" aria-label="System highlights">
        <li>{{ hero_label_1 | escape }}</li>
        <li>{{ hero_label_2 | escape }}</li>
      </ul>
    </div>
  </div>
</section>

<nav class="btx-hero-cta{% if section.settings.enable_sticky_cta %} btx-hero-cta--sticky{% endif %}" aria-label="TermBar system shortcuts">
  <div class="btx-hero-cta__inner">
    {%- if section.settings.cta_1_label != blank and section.settings.cta_1_url != blank -%}
      <a class="btx-hero-cta__btn" href="{{ section.settings.cta_1_url }}">
        <span>{{ section.settings.cta_1_label | escape }}</span>
        <span class="btx-hero-cta__arrow" aria-hidden="true">›</span>
      </a>
    {%- endif -%}
    {%- if section.settings.cta_2_label != blank and section.settings.cta_2_url != blank -%}
      <a class="btx-hero-cta__btn" href="{{ section.settings.cta_2_url }}">
        <span>{{ section.settings.cta_2_label | escape }}</span>
        <span class="btx-hero-cta__arrow" aria-hidden="true">›</span>
      </a>
    {%- endif -%}
    {%- if section.settings.cta_3_label != blank and section.settings.cta_3_url != blank -%}
      <a class="btx-hero-cta__btn" href="{{ section.settings.cta_3_url }}">
        <span>{{ section.settings.cta_3_label | escape }}</span>
        <span class="btx-hero-cta__arrow" aria-hidden="true">›</span>
      </a>
    {%- endif -%}
    {%- if section.settings.cta_4_label != blank and section.settings.cta_4_url != blank -%}
      <a class="btx-hero-cta__btn" href="{{ section.settings.cta_4_url }}">
        <span>{{ section.settings.cta_4_label | escape }}</span>
        <span class="btx-hero-cta__arrow" aria-hidden="true">›</span>
      </a>
    {%- endif -%}
  </div>
</nav>

{% schema %}
{
  "name": "BTX TermBar hero",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "BlueTex TermBar Cover System" },
    { "type": "text", "id": "heading", "label": "Headline", "default": "Repair Old or Torn Insulation — Without Tearing It Out" },
    { "type": "text", "id": "sub_label_1", "label": "Sub-label 1", "default": "Tear-Proof / Puncture-Resistant" },
    { "type": "text", "id": "sub_label_2", "label": "Sub-label 2", "default": "Internal Vapor Barrier Replacement System" },
    {
      "type": "select",
      "id": "media_type",
      "label": "Media type",
      "default": "video",
      "options": [
        { "value": "image", "label": "Still image" },
        { "value": "video", "label": "Muted looping video" }
      ]
    },
    { "type": "image_picker", "id": "image", "label": "Still image (fallback)" },
    { "type": "url", "id": "video_url", "label": "MP4 video URL (external)" },
    { "type": "text", "id": "video_asset_filename", "label": "MP4 asset filename (theme asset)", "info": "Overrides external URL. Example: BlueTexHorizontalAd.mp4" },
    { "type": "image_picker", "id": "poster", "label": "Video poster image" },
    { "type": "text", "id": "image_alt", "label": "Media alt text" },
    { "type": "checkbox", "id": "enable_sticky_cta", "label": "Make CTA bar sticky on scroll", "default": true },
    { "type": "text", "id": "cta_1_label", "label": "CTA 1 label", "default": "System Overview" },
    { "type": "url", "id": "cta_1_url", "label": "CTA 1 link" },
    { "type": "text", "id": "cta_2_label", "label": "CTA 2 label", "default": "Install Guide" },
    { "type": "url", "id": "cta_2_url", "label": "CTA 2 link" },
    { "type": "text", "id": "cta_3_label", "label": "CTA 3 label", "default": "Order Test Kit" },
    { "type": "url", "id": "cta_3_url", "label": "CTA 3 link" },
    { "type": "text", "id": "cta_4_label", "label": "CTA 4 label", "default": "Request a Quote" },
    { "type": "url", "id": "cta_4_url", "label": "CTA 4 link" }
  ],
  "presets": [
    { "name": "BTX TermBar hero" }
  ]
}
{% endschema %}

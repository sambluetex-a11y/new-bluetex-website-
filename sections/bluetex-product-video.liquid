<section id="BlueTexProductVideo-{{ section.id }}" class="bt-product-video">
  <div class="bt-product-video__container">
    <div class="bt-product-video__label">
      <span>{{ section.settings.heading }}</span>
      {%- if section.settings.link_label != blank -%}<a href="{{ section.settings.link }}">{{ section.settings.link_label }}</a>{%- endif -%}
    </div>
    <div class="bt-product-video__frame">
      {%- if section.settings.video_url != blank -%}
        {%- if section.settings.video_url.type == 'youtube' -%}
          <iframe src="https://www.youtube.com/embed/{{ section.settings.video_url.id }}" title="{{ section.settings.heading | escape }}" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen></iframe>
        {%- elsif section.settings.video_url.type == 'vimeo' -%}
          <iframe src="https://player.vimeo.com/video/{{ section.settings.video_url.id }}" title="{{ section.settings.heading | escape }}" allow="autoplay; fullscreen; picture-in-picture" allowfullscreen></iframe>
        {%- endif -%}
      {%- elsif section.settings.embed != blank -%}
        {{ section.settings.embed }}
      {%- else -%}
        <span>Add video URL</span>
      {%- endif -%}
    </div>
    {%- if section.settings.caption != blank -%}<p>{{ section.settings.caption }}</p>{%- endif -%}
  </div>
</section>

<style>
  #BlueTexProductVideo-{{ section.id }} { --bt-navy:#0011a7; --bt-orange:#ee7f12; --bt-ink:#1b1b1b; --bt-muted:#535254; --bt-line:#e6e6e7; font-family:Lato,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif; background:#fff; padding:48px 0; }
  #BlueTexProductVideo-{{ section.id }} * { box-sizing:border-box; }
  #BlueTexProductVideo-{{ section.id }} .bt-product-video__container { max-width:1140px; margin:0 auto; padding:0 20px; }
  #BlueTexProductVideo-{{ section.id }} .bt-product-video__label { background:#e6e6e6; border-left:4px solid var(--bt-navy); padding:14px 22px; display:flex; align-items:center; justify-content:space-between; gap:12px; color:var(--bt-ink); font-size:18px; font-weight:700; letter-spacing:1.4px; line-height:1.2; text-transform:uppercase; }
  #BlueTexProductVideo-{{ section.id }} .bt-product-video__label a { color:var(--bt-navy); font-size:12px; font-weight:700; letter-spacing:.8px; text-decoration:none; white-space:nowrap; }
  #BlueTexProductVideo-{{ section.id }} .bt-product-video__label a:hover { color:var(--bt-orange); }
  #BlueTexProductVideo-{{ section.id }} .bt-product-video__frame { max-width:920px; margin:18px auto 0; aspect-ratio:16/9; border:1px solid var(--bt-line); border-radius:6px; background:#000; overflow:hidden; display:flex; align-items:center; justify-content:center; color:#fff; font-size:12px; font-weight:700; letter-spacing:1.4px; text-transform:uppercase; }
  #BlueTexProductVideo-{{ section.id }} .bt-product-video__frame iframe { width:100%; height:100%; border:0; display:block; }
  #BlueTexProductVideo-{{ section.id }} p { margin:14px 0 0; color:var(--bt-muted); text-align:center; font-size:12px; font-weight:700; letter-spacing:1.2px; text-transform:uppercase; }
  @media (max-width: 560px) { #BlueTexProductVideo-{{ section.id }} { padding:32px 0; } #BlueTexProductVideo-{{ section.id }} .bt-product-video__container { padding:0 16px; } #BlueTexProductVideo-{{ section.id }} .bt-product-video__label { align-items:flex-start; flex-direction:column; } }
</style>

{% schema %}
{
  "name": "BlueTex Product Video",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "See the System in Action" },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "View Case Studies →" },
    { "type": "url", "id": "link", "label": "Link" },
    { "type": "video_url", "id": "video_url", "label": "YouTube or Vimeo URL", "accept": ["youtube", "vimeo"] },
    { "type": "html", "id": "embed", "label": "Fallback embed HTML" },
    { "type": "text", "id": "caption", "label": "Caption", "default": "BlueTex Cover & Repair · TermBar install on a metal building" }
  ],
  "presets": [
    { "name": "BlueTex Product Video" }
  ]
}
{% endschema %}

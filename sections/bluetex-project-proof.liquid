<section id="BlueTexProjectProof-{{ section.id }}" class="bt-project-proof">
  <div class="bt-project-proof__container">
    <div class="bt-project-proof__label">
      <span>{{ section.settings.heading }}</span>
      {%- if section.settings.link_label != blank -%}<a href="{{ section.settings.link }}">{{ section.settings.link_label }}</a>{%- endif -%}
    </div>
    <div class="bt-project-proof__grid">
      {%- for block in section.blocks -%}
        <div class="bt-project-proof__card" {{ block.shopify_attributes }}>
          <div class="bt-project-proof__image">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', widths: '350, 550, 800', sizes: '(min-width: 990px) 33vw, 100vw', alt: block.settings.alt }}
            {%- else -%}
              <span>{{ block.settings.image_label }}</span>
            {%- endif -%}
          </div>
          <div class="bt-project-proof__body">
            <strong>{{ block.settings.title }}</strong>
            <p>{{ block.settings.text }}</p>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  #BlueTexProjectProof-{{ section.id }} { --bt-navy:#0011a7; --bt-orange:#ee7f12; --bt-ink:#1b1b1b; --bt-muted:#535254; --bt-soft:#e6e6e7; --bt-grey:#eeeeee; font-family:Lato,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif; background:#eeeeee; padding:40px 0 52px; }
  #BlueTexProjectProof-{{ section.id }} * { box-sizing:border-box; }
  #BlueTexProjectProof-{{ section.id }} .bt-project-proof__container { max-width:1140px; margin:0 auto; padding:0 20px; }
  #BlueTexProjectProof-{{ section.id }} .bt-project-proof__label { background:#e6e6e6; border-left:4px solid var(--bt-navy); padding:14px 22px; display:flex; align-items:center; justify-content:space-between; gap:12px; color:var(--bt-ink); font-size:18px; line-height:1.2; font-weight:700; letter-spacing:1.4px; text-transform:uppercase; }
  #BlueTexProjectProof-{{ section.id }} .bt-project-proof__label a { color:var(--bt-navy); font-size:12px; font-weight:700; letter-spacing:.8px; text-decoration:none; white-space:nowrap; }
  #BlueTexProjectProof-{{ section.id }} .bt-project-proof__label a:hover { color:var(--bt-orange); }
  #BlueTexProjectProof-{{ section.id }} .bt-project-proof__grid { display:grid; grid-template-columns:repeat(3,1fr); gap:14px; margin-top:18px; }
  #BlueTexProjectProof-{{ section.id }} .bt-project-proof__card { background:#fff; border:1px solid var(--bt-soft); border-radius:2px; overflow:hidden; }
  #BlueTexProjectProof-{{ section.id }} .bt-project-proof__image { aspect-ratio:4/3; background:#ddd; display:flex; align-items:center; justify-content:center; color:var(--bt-navy); font-size:11px; font-weight:700; letter-spacing:1.4px; text-transform:uppercase; }
  #BlueTexProjectProof-{{ section.id }} .bt-project-proof__image img { width:100%; height:100%; object-fit:cover; display:block; }
  #BlueTexProjectProof-{{ section.id }} .bt-project-proof__body { padding:14px 16px 16px; border-top:4px solid var(--bt-navy); }
  #BlueTexProjectProof-{{ section.id }} .bt-project-proof__card:nth-child(2n) .bt-project-proof__body { border-top-color:var(--bt-orange); }
  #BlueTexProjectProof-{{ section.id }} .bt-project-proof__body strong { display:block; color:var(--bt-navy); font-size:14px; line-height:1.25; font-weight:700; letter-spacing:.4px; text-transform:uppercase; margin-bottom:4px; }
  #BlueTexProjectProof-{{ section.id }} .bt-project-proof__body p { margin:0; color:var(--bt-muted); font-size:13px; line-height:1.45; }
  @media (max-width: 900px) { #BlueTexProjectProof-{{ section.id }} .bt-project-proof__grid { grid-template-columns:1fr; } }
  @media (max-width: 560px) { #BlueTexProjectProof-{{ section.id }} { padding:32px 0; } #BlueTexProjectProof-{{ section.id }} .bt-project-proof__container { padding:0 16px; } #BlueTexProjectProof-{{ section.id }} .bt-project-proof__label { align-items:flex-start; flex-direction:column; } }
</style>

{% schema %}
{
  "name": "BlueTex Project Proof",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Case Studies & Install Gallery" },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "View Full Gallery →" },
    { "type": "url", "id": "link", "label": "Link" }
  ],
  "blocks": [
    {
      "type": "proof",
      "name": "Proof card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "alt", "label": "Image alt", "default": "BlueTex install photo" },
        { "type": "text", "id": "image_label", "label": "Placeholder label", "default": "Install photo" },
        { "type": "text", "id": "title", "label": "Title", "default": "After · Finished Roof & Wall" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Full retrofit with TermBar install, walls and roof." }
      ]
    }
  ],
  "presets": [
    {
      "name": "BlueTex Project Proof",
      "blocks": [
        { "type": "proof", "settings": { "image_label": "Before Photo", "title": "Before · Sagging Insulation", "text": "Old vinyl-faced insulation pulling away from the purlins." } },
        { "type": "proof", "settings": { "image_label": "After Photo", "title": "After · Finished Roof & Wall", "text": "Full retrofit with TermBar install, walls and roof." } },
        { "type": "proof", "settings": { "image_label": "Wall Finish", "title": "Complete Wall Finish", "text": "Flat, drum-tight, bright white finished interior wall." } }
      ]
    }
  ]
}
{% endschema %}

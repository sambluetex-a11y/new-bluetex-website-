<section id="BlueTexTermbarSolution-{{ section.id }}" class="bt-tbsolution">
  <div class="bt-tbsolution__wrap">
    <div class="bt-tbsolution__copy">
      {%- if section.settings.eyebrow != blank -%}
        <span class="bt-tbsolution__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2>{{ section.settings.heading }}</h2>
      <p class="bt-tbsolution__lead">{{ section.settings.lead }}</p>
      <ul class="bt-tbsolution__points">
        {%- for block in section.blocks -%}
          <li {{ block.shopify_attributes }}>
            <strong>{{ block.settings.title }}</strong>
            <span>{{ block.settings.text }}</span>
          </li>
        {%- endfor -%}
      </ul>
    </div>
    <div class="bt-tbsolution__media">
      {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', widths: '500, 800, 1100, 1200', sizes: '(min-width: 990px) 50vw, 100vw', alt: section.settings.image_alt }}
      {%- else -%}
        <div class="bt-tbsolution__placeholder">Add TermBar install image</div>
      {%- endif -%}
      {%- if section.settings.image_label != blank -%}
        <span class="bt-tbsolution__media-label">{{ section.settings.image_label }}</span>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  #BlueTexTermbarSolution-{{ section.id }} { --bt-navy:#0011a7; --bt-deep:#002f6c; --bt-orange:#ee7f12; --bt-text:#1b1b1b; --bt-muted:#535254; --bt-soft:#e6e6e7; font-family:Lato,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif; background:#eeeeee; padding:56px 20px; }
  #BlueTexTermbarSolution-{{ section.id }} * { box-sizing:border-box; }
  #BlueTexTermbarSolution-{{ section.id }} .bt-tbsolution__wrap { max-width:1140px; margin:0 auto; display:grid; grid-template-columns:1.1fr 1fr; gap:36px; align-items:center; }
  #BlueTexTermbarSolution-{{ section.id }} .bt-tbsolution__eyebrow { display:inline-block; background:var(--bt-orange); color:#fff; font-size:11px; font-weight:700; letter-spacing:1.6px; text-transform:uppercase; padding:5px 12px; border-radius:2px; margin-bottom:12px; }
  #BlueTexTermbarSolution-{{ section.id }} h2 { margin:0 0 12px; color:var(--bt-navy); font-size:30px; line-height:1.1; font-weight:700; letter-spacing:.2px; text-transform:uppercase; }
  #BlueTexTermbarSolution-{{ section.id }} .bt-tbsolution__lead { margin:0 0 18px; color:var(--bt-text); font-size:16px; line-height:1.55; }
  #BlueTexTermbarSolution-{{ section.id }} .bt-tbsolution__points { list-style:none; margin:0; padding:0; display:flex; flex-direction:column; gap:10px; }
  #BlueTexTermbarSolution-{{ section.id }} .bt-tbsolution__points li { display:grid; grid-template-columns:14px 1fr; gap:14px; align-items:flex-start; padding:14px 16px; background:#fff; border:1px solid var(--bt-soft); border-radius:4px; }
  #BlueTexTermbarSolution-{{ section.id }} .bt-tbsolution__points li:before { content:""; width:10px; height:10px; margin-top:6px; background:var(--bt-orange); border-radius:2px; }
  #BlueTexTermbarSolution-{{ section.id }} .bt-tbsolution__points strong { display:block; color:var(--bt-deep); font-size:14px; font-weight:700; letter-spacing:.4px; text-transform:uppercase; margin-bottom:2px; }
  #BlueTexTermbarSolution-{{ section.id }} .bt-tbsolution__points span { display:block; color:var(--bt-muted); font-size:14px; line-height:1.55; }
  #BlueTexTermbarSolution-{{ section.id }} .bt-tbsolution__media { position:relative; min-height:380px; background:var(--bt-deep); border-radius:6px; overflow:hidden; }
  #BlueTexTermbarSolution-{{ section.id }} .bt-tbsolution__media img { width:100%; height:100%; min-height:380px; object-fit:cover; display:block; }
  #BlueTexTermbarSolution-{{ section.id }} .bt-tbsolution__placeholder { min-height:380px; display:flex; align-items:center; justify-content:center; color:#fff; font-size:12px; font-weight:700; letter-spacing:1.4px; text-transform:uppercase; border:1px dashed rgba(255,255,255,.35); }
  #BlueTexTermbarSolution-{{ section.id }} .bt-tbsolution__media-label { position:absolute; left:16px; bottom:16px; background:rgba(238,127,18,.94); color:#fff; padding:5px 10px; border-radius:2px; font-size:11px; font-weight:700; letter-spacing:1.6px; text-transform:uppercase; }
  @media (max-width: 990px) { #BlueTexTermbarSolution-{{ section.id }} .bt-tbsolution__wrap { grid-template-columns:1fr; } #BlueTexTermbarSolution-{{ section.id }} h2 { font-size:24px; } }
  @media (max-width: 560px) { #BlueTexTermbarSolution-{{ section.id }} { padding:40px 16px; } }
</style>

{% schema %}
{
  "name": "BlueTex TermBar Solution",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The Solution" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Cover It With BlueTex and TermBars" },
    { "type": "textarea", "id": "lead", "label": "Lead text", "default": "BlueTex installs directly over the existing insulation — no demo, no fiberglass cleanup. Sheets are mechanically locked to the building at every purlin with aluminum TermBars, sealing the building behind a single continuous, washable surface." },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "image_alt", "label": "Image alt text", "default": "Finished BlueTex install with aluminum TermBars" },
    { "type": "text", "id": "image_label", "label": "Image label", "default": "BlueTex 2mm Pro · TermBar install" }
  ],
  "blocks": [
    {
      "type": "point",
      "name": "Point",
      "settings": [
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "textarea", "id": "text", "label": "Text" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "BlueTex TermBar Solution",
      "blocks": [
        { "type": "point", "settings": { "title": "Goes Over the Old Stuff", "text": "Install directly over torn or sagging insulation. No tearing out fiberglass, no dust, no cleanup." } },
        { "type": "point", "settings": { "title": "Mechanically Locked at Purlins", "text": "Aluminum TermBars screw through BlueTex into every purlin, sealing the building edge-to-edge with no adhesives or staples." } },
        { "type": "point", "settings": { "title": "New Vapor Barrier and Finish In One", "text": "BlueTex is the new finished interior surface — a continuous vapor barrier and a clean, washable white face." } }
      ]
    }
  ]
}
{% endschema %}

{% render 'bluetex-product-block-section', mode: 'chooser' %}

{% schema %}
{
  "name": "BlueTex Product Chooser",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Choose the Right Option" },
    { "type": "textarea", "id": "text", "label": "Intro text", "default": "A quick product-specific guide to help choose the right variant or system path." },
    { "type": "select", "id": "background", "label": "Background", "options": [{ "value": "white", "label": "White" }, { "value": "grey", "label": "Light gray" }], "default": "grey" },
    { "type": "range", "id": "columns", "label": "Columns", "min": 2, "max": 4, "step": 1, "default": 4 },
    { "type": "text", "id": "link_label", "label": "Link label" },
    { "type": "url", "id": "link", "label": "Link" }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Chooser item",
      "settings": [
        { "type": "text", "id": "kicker", "label": "Kicker", "default": "Option" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Compare before ordering" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Keep this short and decision-focused." }
      ]
    }
  ],
  "presets": [{ "name": "BlueTex Product Chooser" }]
}
{% endschema %}

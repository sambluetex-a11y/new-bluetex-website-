<section id="BlueTexProductFaq-{{ section.id }}" class="bt-product-faq">
  <div class="bt-product-faq__container">
    <div class="bt-product-faq__label">
      <span>{{ section.settings.heading }}</span>
      {%- if section.settings.link_label != blank -%}<a href="{{ section.settings.link }}">{{ section.settings.link_label }}</a>{%- endif -%}
    </div>
    <div class="bt-product-faq__grid">
      {%- for block in section.blocks -%}
        <article class="bt-product-faq__card" {{ block.shopify_attributes }}>
          <h3>{{ block.settings.question }}</h3>
          <p>{{ block.settings.answer }}</p>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  #BlueTexProductFaq-{{ section.id }} { --bt-navy:#0011a7; --bt-orange:#ee7f12; --bt-ink:#1b1b1b; --bt-text:#1b1b1b; --bt-soft:#e6e6e7; --bt-grey:#eeeeee; font-family:Lato,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif; background:#eeeeee; padding:48px 0; }
  #BlueTexProductFaq-{{ section.id }} * { box-sizing:border-box; }
  #BlueTexProductFaq-{{ section.id }} .bt-product-faq__container { max-width:1140px; margin:0 auto; padding:0 20px; }
  #BlueTexProductFaq-{{ section.id }} .bt-product-faq__label { background:#e6e6e6; border-left:4px solid var(--bt-navy); padding:14px 22px; display:flex; align-items:center; justify-content:space-between; gap:12px; color:var(--bt-ink); font-size:18px; font-weight:700; letter-spacing:1.4px; line-height:1.2; text-transform:uppercase; }
  #BlueTexProductFaq-{{ section.id }} .bt-product-faq__label a { color:var(--bt-navy); font-size:12px; font-weight:700; letter-spacing:.8px; text-decoration:none; white-space:nowrap; }
  #BlueTexProductFaq-{{ section.id }} .bt-product-faq__label a:hover { color:var(--bt-orange); }
  #BlueTexProductFaq-{{ section.id }} .bt-product-faq__grid { display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-top:18px; }
  #BlueTexProductFaq-{{ section.id }} .bt-product-faq__card { background:#fff; border:1px solid var(--bt-soft); border-left:4px solid var(--bt-orange); border-radius:2px; padding:20px 22px 22px; }
  #BlueTexProductFaq-{{ section.id }} .bt-product-faq__card h3 { margin:0 0 8px; color:var(--bt-navy); font-size:15px; line-height:1.25; font-weight:700; letter-spacing:.4px; text-transform:uppercase; }
  #BlueTexProductFaq-{{ section.id }} .bt-product-faq__card p { margin:0; color:var(--bt-text); font-size:14px; line-height:1.5; }
  @media (max-width: 760px) { #BlueTexProductFaq-{{ section.id }} .bt-product-faq__grid { grid-template-columns:1fr; } }
  @media (max-width: 560px) { #BlueTexProductFaq-{{ section.id }} { padding:32px 0; } #BlueTexProductFaq-{{ section.id }} .bt-product-faq__container { padding:0 16px; } #BlueTexProductFaq-{{ section.id }} .bt-product-faq__label { align-items:flex-start; flex-direction:column; } }
</style>

{% schema %}
{
  "name": "BlueTex Product FAQ",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Common Questions" },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "View Full FAQ →" },
    { "type": "url", "id": "link", "label": "Link" }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "Question",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "Is the $100 really refundable?" },
        { "type": "textarea", "id": "answer", "label": "Answer", "default": "It's redeemable, not refunded in cash. Place a follow-on order of $500 or more and we credit the $100 against the new order. One credit per $500 of purchase." }
      ]
    }
  ],
  "presets": [
    {
      "name": "BlueTex Product FAQ",
      "blocks": [
        { "type": "question", "settings": { "question": "Is the $100 really refundable?", "answer": "It's redeemable, not refunded in cash. Place a follow-on order of $500 or more and we credit the $100 against the new order. One credit per $500 of purchase." } },
        { "type": "question", "settings": { "question": "Why 50″ wide and not something wider?", "answer": "50 inches is the width we recommend for metal building cover and repair work. It lines up cleanly with common purlin and girt spacing and keeps the install fast." } },
        { "type": "question", "settings": { "question": "Do I have to tear out the old insulation first?", "answer": "Usually no. BlueTex is most often installed over the existing insulation. The TermBar presses the old material in place and the new BlueTex creates the finished interior." } },
        { "type": "question", "settings": { "question": "Will this work on a red iron building?", "answer": "Yes. The kit includes a sample set of EasyClips specifically for attaching BlueTex to the roofline on a red iron style building, plus TermBars for the wall sections." } },
        { "type": "question", "settings": { "question": "How big a section can I cover with one kit?", "answer": "One bay. The kit covers roughly 20 ft of 50-inch-wide material, enough to install one full TermBar run between two purlins or girts." } },
        { "type": "question", "settings": { "question": "What's the next step after I test the kit?", "answer": "Send us photos of your building and the basic dimensions. We'll put together a material list and a quote. Use the $100 from the kit toward that order." } }
      ]
    }
  ]
}
{% endschema %}

{% render 'bluetex-product-main', section: section, product: product %}
{% schema %}
{
  "name": "BlueTex Door Main",
  "settings": [
    { "type": "text", "id": "media_badge", "label": "Media badge", "default": "Door Kit" },
    { "type": "text", "id": "media_placeholder", "label": "Media placeholder", "default": "Door kit media" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Garage & Roll-Up Door Insulation" },
    { "type": "text", "id": "fallback_title", "label": "Fallback title", "default": "BlueTex™ Door Insulation Kit" },
    { "type": "textarea", "id": "subheadline", "label": "Subheadline", "default": "BlueTex 2mm Pro door kits help reduce radiant heat through residential panel doors and commercial roll-up doors." },
    { "type": "text", "id": "price_note", "label": "Price note", "default": "Choose the kit size that matches your door" },
    { "type": "text", "id": "variant_label", "label": "Variant label", "default": "Kit size" },
    { "type": "text", "id": "quantity_label", "label": "Quantity label", "default": "Quantity" },
    { "type": "text", "id": "add_to_cart_label", "label": "Add to cart label", "default": "Add Door Kit to Cart" },
    { "type": "checkbox", "id": "show_dynamic_checkout", "label": "Show dynamic checkout button", "default": true },
    { "type": "text", "id": "quote_label", "label": "Help button label", "default": "Get Help With Multiple Doors" },
    { "type": "url", "id": "quote_link", "label": "Help button link" }
  ],
  "blocks": [
    { "type": "bullet", "name": "Bullet", "settings": [{ "type": "text", "id": "text", "label": "Text", "default": "Measure the door first, then choose the kit that matches the door style and size." }] },
    { "type": "trust", "name": "Trust block", "settings": [{ "type": "text", "id": "icon", "label": "Icon text", "default": "D" }, { "type": "text", "id": "heading", "label": "Heading", "default": "Door Fit" }, { "type": "text", "id": "text", "label": "Text", "default": "Built for door panels and roll-up door insulation projects." }] }
  ],
  "presets": [
    {
      "name": "BlueTex Door Main",
      "blocks": [
        { "type": "bullet", "settings": { "text": "Choose residential panel door or commercial roll-up door based on your door style." } },
        { "type": "bullet", "settings": { "text": "Includes BlueTex 2mm Pro material and the attachment parts for the kit style." } },
        { "type": "bullet", "settings": { "text": "Measure each door before ordering, especially for larger doors or multiple doors." } },
        { "type": "trust", "settings": { "icon": "R", "heading": "Residential Doors", "text": "For common sectional garage door panels." } },
        { "type": "trust", "settings": { "icon": "U", "heading": "Roll-Up Doors", "text": "For commercial roll-up door applications." } },
        { "type": "trust", "settings": { "icon": "M", "heading": "Measure First", "text": "Door width and height drive kit choice." } },
        { "type": "trust", "settings": { "icon": "H", "heading": "Help Available", "text": "Ask for help on large or multiple-door projects." } }
      ]
    }
  ]
}
{% endschema %}

<section id="BlueTexBoxContents-{{ section.id }}" class="bt-box-contents">
  <div class="bt-box-contents__container">
    <div class="bt-box-contents__label">
      <span>{{ section.settings.heading }}</span>
      {%- if section.settings.link_label != blank -%}<a href="{{ section.settings.link }}">{{ section.settings.link_label }}</a>{%- endif -%}
    </div>
    <div class="bt-box-contents__grid">
      {%- for block in section.blocks -%}
        <article class="bt-box-contents__card" {{ block.shopify_attributes }}>
          <span>{{ block.settings.qty }}</span>
          <h3>{{ block.settings.heading }}</h3>
          <p>{{ block.settings.text }}</p>
        </article>
      {%- endfor -%}
    </div>
    {%- if section.settings.summary != blank -%}
      <div class="bt-box-contents__summary">
        <strong>{{ section.settings.summary_heading }}</strong>
        <p>{{ section.settings.summary }}</p>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  #BlueTexBoxContents-{{ section.id }} { --bt-navy:#0011a7; --bt-orange:#ee7f12; --bt-ink:#1b1b1b; --bt-text:#1b1b1b; --bt-soft:#e6e6e7; --bt-grey:#eeeeee; font-family:Lato,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif; background:#eeeeee; padding:48px 0; }
  #BlueTexBoxContents-{{ section.id }} * { box-sizing:border-box; }
  #BlueTexBoxContents-{{ section.id }} .bt-box-contents__container { max-width:1140px; margin:0 auto; padding:0 20px; }
  #BlueTexBoxContents-{{ section.id }} .bt-box-contents__label { background:#e6e6e6; border-left:4px solid var(--bt-navy); padding:14px 22px; display:flex; align-items:center; justify-content:space-between; gap:12px; color:var(--bt-ink); font-size:18px; font-weight:700; letter-spacing:1.4px; line-height:1.2; text-transform:uppercase; }
  #BlueTexBoxContents-{{ section.id }} .bt-box-contents__label a { color:var(--bt-navy); font-size:12px; font-weight:700; letter-spacing:.8px; text-decoration:none; white-space:nowrap; }
  #BlueTexBoxContents-{{ section.id }} .bt-box-contents__label a:hover { color:var(--bt-orange); }
  #BlueTexBoxContents-{{ section.id }} .bt-box-contents__grid { display:grid; grid-template-columns:repeat(5,1fr); gap:14px; margin-top:18px; }
  #BlueTexBoxContents-{{ section.id }} .bt-box-contents__card { background:#fff; border:1px solid var(--bt-soft); border-top:4px solid var(--bt-navy); border-radius:2px; padding:18px 18px 20px; }
  #BlueTexBoxContents-{{ section.id }} .bt-box-contents__card:nth-child(2n) { border-top-color:var(--bt-orange); }
  #BlueTexBoxContents-{{ section.id }} .bt-box-contents__card span { display:block; color:var(--bt-orange); font-size:11px; font-weight:700; letter-spacing:1.6px; text-transform:uppercase; margin-bottom:6px; }
  #BlueTexBoxContents-{{ section.id }} .bt-box-contents__card h3 { margin:0 0 7px; color:var(--bt-navy); font-size:14px; line-height:1.25; font-weight:700; letter-spacing:.4px; text-transform:uppercase; }
  #BlueTexBoxContents-{{ section.id }} .bt-box-contents__card p { margin:0; color:var(--bt-text); font-size:13px; line-height:1.45; }
  #BlueTexBoxContents-{{ section.id }} .bt-box-contents__summary { margin-top:18px; background:#fff; border:1px solid var(--bt-soft); border-left:4px solid var(--bt-navy); border-radius:2px; padding:18px 22px; }
  #BlueTexBoxContents-{{ section.id }} .bt-box-contents__summary strong { display:block; color:var(--bt-navy); font-size:12px; font-weight:700; letter-spacing:.4px; text-transform:uppercase; margin-bottom:4px; }
  #BlueTexBoxContents-{{ section.id }} .bt-box-contents__summary p { margin:0; color:var(--bt-text); font-size:14px; line-height:1.55; }
  @media (max-width: 1080px) { #BlueTexBoxContents-{{ section.id }} .bt-box-contents__grid { grid-template-columns:repeat(3,1fr); } }
  @media (max-width: 760px) { #BlueTexBoxContents-{{ section.id }} .bt-box-contents__grid { grid-template-columns:repeat(2,1fr); } }
  @media (max-width: 560px) { #BlueTexBoxContents-{{ section.id }} { padding:32px 0; } #BlueTexBoxContents-{{ section.id }} .bt-box-contents__container { padding:0 16px; } #BlueTexBoxContents-{{ section.id }} .bt-box-contents__grid { grid-template-columns:1fr; } #BlueTexBoxContents-{{ section.id }} .bt-box-contents__label { align-items:flex-start; flex-direction:column; } }
</style>

{% schema %}
{
  "name": "BlueTex Box Contents",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "What's Inside the Sample Box" },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "View Full Spec Sheet →" },
    { "type": "url", "id": "link", "label": "Link" },
    { "type": "text", "id": "summary_heading", "label": "Summary heading", "default": "Why a sample box, not a swatch" },
    { "type": "textarea", "id": "summary", "label": "Summary", "default": "Everything in this kit is full-size. Bring it to the building and test the actual TermBar install, the actual seam tape, and the actual finished look on one section before placing a full-building order." }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Box item",
      "settings": [
        { "type": "text", "id": "qty", "label": "Quantity", "default": "Qty 1 · 20 ft" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "BlueTex™ 2mm Pro 50″" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "A 20-foot length of our 50-inch-wide 2mm Pro material used on full-building Cover & Repair installs." }
      ]
    }
  ],
  "presets": [
    {
      "name": "BlueTex Box Contents",
      "blocks": [
        { "type": "item", "settings": { "qty": "Qty 1 · 20 ft", "heading": "BlueTex™ 2mm Pro 50″", "text": "A 20-foot length of our 50-inch-wide 2mm Pro material used on full-building Cover & Repair installs." } },
        { "type": "item", "settings": { "qty": "Qty 4 · 48″ each", "heading": "Aluminum TermBars", "text": "Four 48-inch aluminum TermBars for fastening BlueTex tight to the purlins and girts on a metal building." } },
        { "type": "item", "settings": { "qty": "Qty 15", "heading": "1″ #10 Hex Screws", "text": "5/16-inch hex-head self-drillers used to attach the TermBars to the building framing." } },
        { "type": "item", "settings": { "qty": "Qty 1 · 30 ft", "heading": "3″ White Vapor Barrier Seam Tape", "text": "White seam tape for sealing the joints between BlueTex panels and maintaining the vapor barrier." } },
        { "type": "item", "settings": { "qty": "Qty 6 · Sample Set", "heading": "EasyClip™ Sample Set", "text": "Sample set of EasyClips for attaching BlueTex to the roofline on a red iron style building." } }
      ]
    }
  ]
}
{% endschema %}

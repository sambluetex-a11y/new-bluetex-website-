{{ 'bluetex-collection.css' | asset_url | stylesheet_tag }}

<section id="BlueTexCollectionFaq-{{ section.id }}" class="btxc btxc__band btxc__band--grey">
  <div class="btxc__container">
    <div class="btxc__label">
      <span>{{ section.settings.heading }}</span>
      {%- if section.settings.link_label != blank -%}<a href="{{ section.settings.link }}">{{ section.settings.link_label }}</a>{%- endif -%}
    </div>
    <div class="btxc-faq__grid">
      {%- for block in section.blocks -%}
        <article class="btxc-faq__item" {{ block.shopify_attributes }}>
          <h3>{{ block.settings.question }}</h3>
          <p>{{ block.settings.answer }}</p>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "BlueTex Collection FAQ",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Collection Questions" },
    { "type": "text", "id": "link_label", "label": "Header link label" },
    { "type": "url", "id": "link", "label": "Header link" }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "Which BlueTex product do I need?" },
        { "type": "textarea", "id": "answer", "label": "Answer", "default": "It depends on the building, existing insulation condition, and install method. Send photos and dimensions if you are planning more than a small repair." }
      ]
    }
  ],
  "presets": [
    {
      "name": "BlueTex Collection FAQ",
      "blocks": [
        { "type": "faq", "settings": { "question": "Which BlueTex product do I need?", "answer": "It depends on the building, existing insulation condition, and install method. Send photos and dimensions if you are planning more than a small repair." } },
        { "type": "faq", "settings": { "question": "Should I order rolls directly or request a quote?", "answer": "For full-building cover or repair, request a quote so rolls, tape, TermBars, and fasteners can be sized as a system." } },
        { "type": "faq", "settings": { "question": "What photos help with a material list?", "answer": "Send wide shots of the interior, problem areas, purlins or girts, corners, doors, and a few measurements of wall or roof runs." } },
        { "type": "faq", "settings": { "question": "Do I need TermBars and tape?", "answer": "Most finished cover and repair projects use TermBars to fasten the material and white vapor barrier tape to seal seams." } },
        { "type": "faq", "settings": { "question": "What if I am repairing existing insulation?", "answer": "BlueTex is commonly used to cover stained, torn, or sagging insulation in metal buildings without removing all existing material first." } }
      ]
    }
  ]
}
{% endschema %}

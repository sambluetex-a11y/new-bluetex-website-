
<section id="BlueTexHero-{{ section.id }}" class="bt-hero">
  <div class="bt-hero__wrap">
    <div class="bt-hero__panel">
      <div class="bt-hero__copy">
        {%- if section.settings.eyebrow != blank -%}
          <span class="bt-hero__eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        <h1>{{ section.settings.heading }}</h1>
        <p>{{ section.settings.text }}</p>
        <div class="bt-hero__buttons">
          {%- if section.settings.primary_label != blank -%}
            <a class="bt-hero__btn bt-hero__btn--orange" href="{{ section.settings.primary_link }}">{{ section.settings.primary_label }}</a>
          {%- endif -%}
          {%- if section.settings.secondary_label != blank -%}
            <a class="bt-hero__btn bt-hero__btn--navy" href="{{ section.settings.secondary_link }}">{{ section.settings.secondary_label }}</a>
          {%- endif -%}
        </div>
        <div class="bt-hero__proof">
          {%- for block in section.blocks -%}
            <span {{ block.shopify_attributes }}>{{ block.settings.text }}</span>
          {%- endfor -%}
        </div>
      </div>
      <div class="bt-hero__media">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 1400 | image_tag: loading: 'eager', widths: '500, 800, 1100, 1400', sizes: '(min-width: 990px) 50vw, 100vw', alt: section.settings.image_alt }}
        {%- else -%}
          <div class="bt-hero__placeholder">Add TermBar install image</div>
        {%- endif -%}
        {%- if section.settings.image_label != blank -%}
          <span class="bt-hero__media-label">{{ section.settings.image_label }}</span>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<style>
  #BlueTexHero-{{ section.id }} {
    --bt-navy:#0011a7; --bt-navy-hov:#3f62c5; --bt-deep:#002f6c; --bt-orange:#ee7f12; --bt-orange-hov:#3f62c5;
    --bt-ink:#1b1b1b; --bt-text:#1b1b1b; --bt-muted:#535254; --bt-line:#e6e6e7; --bt-soft:#e6e6e7; --bt-grey:#eeeeee;
    font-family: Lato, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background:#fff; padding:22px 0 0;
  }
  #BlueTexHero-{{ section.id }} * { box-sizing:border-box; }
  #BlueTexHero-{{ section.id }} .bt-hero__wrap { max-width:1140px; margin:0 auto; padding:0 20px; }
  #BlueTexHero-{{ section.id }} .bt-hero__panel { display:grid; grid-template-columns:1.05fr 1fr; border:1px solid var(--bt-line); border-radius:6px; overflow:hidden; background:#fff; }
  #BlueTexHero-{{ section.id }} .bt-hero__copy { padding:56px 48px; border-right:1px solid var(--bt-line); display:flex; flex-direction:column; justify-content:center; }
  #BlueTexHero-{{ section.id }} .bt-hero__eyebrow { align-self:flex-start; background:var(--bt-orange); color:#fff; font-size:11px; font-weight:700; letter-spacing:1.6px; text-transform:uppercase; padding:5px 12px; border-radius:2px; margin-bottom:12px; }
  #BlueTexHero-{{ section.id }} h1 { margin:0 0 14px; color:var(--bt-navy); font-size:42px; line-height:1.06; font-weight:700; letter-spacing:-.2px; text-transform:uppercase; }
  #BlueTexHero-{{ section.id }} p { margin:0 0 22px; color:var(--bt-text); font-size:16px; line-height:1.55; }
  #BlueTexHero-{{ section.id }} .bt-hero__buttons { display:flex; gap:10px; flex-wrap:wrap; }
  #BlueTexHero-{{ section.id }} .bt-hero__btn { display:inline-flex; align-items:center; justify-content:center; padding:16px 28px; border-radius:4px; border:2px solid transparent; font-size:14px; font-weight:700; letter-spacing:.8px; line-height:1.1; text-transform:uppercase; text-decoration:none; transition:background .12s ease,border-color .12s ease,color .12s ease; }
  #BlueTexHero-{{ section.id }} .bt-hero__btn--orange { background:var(--bt-navy); color:#fff; border-color:var(--bt-navy); }
  #BlueTexHero-{{ section.id }} .bt-hero__btn--orange:hover { background:var(--bt-navy-hov); border-color:var(--bt-navy-hov); }
  #BlueTexHero-{{ section.id }} .bt-hero__btn--navy { background:var(--bt-navy); color:#fff; border-color:var(--bt-navy); }
  #BlueTexHero-{{ section.id }} .bt-hero__btn--navy:hover { background:var(--bt-navy-hov); border-color:var(--bt-navy-hov); }
  #BlueTexHero-{{ section.id }} .bt-hero__proof { display:flex; gap:18px; margin-top:22px; flex-wrap:wrap; color:var(--bt-navy); font-size:12px; font-weight:700; letter-spacing:.8px; text-transform:uppercase; }
  #BlueTexHero-{{ section.id }} .bt-hero__proof span { display:inline-flex; align-items:center; gap:8px; }
  #BlueTexHero-{{ section.id }} .bt-hero__proof span:before { content:""; width:10px; height:10px; background:var(--bt-orange); border-radius:2px; }
  #BlueTexHero-{{ section.id }} .bt-hero__media { position:relative; min-height:420px; background:var(--bt-deep); overflow:hidden; }
  #BlueTexHero-{{ section.id }} .bt-hero__media img { width:100%; height:100%; min-height:420px; object-fit:cover; display:block; }
  #BlueTexHero-{{ section.id }} .bt-hero__media:after { content:""; position:absolute; inset:0; background:linear-gradient(180deg,rgba(12,23,66,0) 58%,rgba(12,23,66,.58)); pointer-events:none; }
  #BlueTexHero-{{ section.id }} .bt-hero__media-label { position:absolute; left:20px; bottom:20px; z-index:1; background:rgba(238,127,18,.94); color:#fff; padding:5px 10px; border-radius:2px; font-size:11px; font-weight:700; letter-spacing:1.6px; text-transform:uppercase; }
  #BlueTexHero-{{ section.id }} .bt-hero__placeholder { min-height:420px; display:flex; align-items:center; justify-content:center; color:#fff; font-size:12px; font-weight:700; letter-spacing:1.4px; text-transform:uppercase; border:1px dashed rgba(255,255,255,.35); }
  @media (max-width: 990px) {
    #BlueTexHero-{{ section.id }} .bt-hero__panel { grid-template-columns:1fr; }
    #BlueTexHero-{{ section.id }} .bt-hero__copy { padding:36px 28px; border-right:0; border-bottom:1px solid var(--bt-line); }
    #BlueTexHero-{{ section.id }} h1 { font-size:30px; }
    #BlueTexHero-{{ section.id }} .bt-hero__media, #BlueTexHero-{{ section.id }} .bt-hero__media img, #BlueTexHero-{{ section.id }} .bt-hero__placeholder { min-height:300px; }
  }
  @media (max-width: 560px) {
    #BlueTexHero-{{ section.id }} .bt-hero__wrap { padding:0 16px; }
    #BlueTexHero-{{ section.id }} .bt-hero__copy { padding:28px 22px; }
    #BlueTexHero-{{ section.id }} h1 { font-size:26px; }
    #BlueTexHero-{{ section.id }} .bt-hero__btn { width:100%; }
  }
</style>

{% schema %}
{
  "name": "BlueTex Hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Cover · Repair · Retrofit" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Fix Old Metal Building Insulation Without Tearing It Out" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Cover torn, stained, or sagging insulation with a clean BlueTex finish using the TermBar system. Built for metal buildings, pole barns, shops, and hangars." },
    { "type": "text", "id": "primary_label", "label": "Primary button label", "default": "Request a Quote" },
    { "type": "url", "id": "primary_link", "label": "Primary button link" },
    { "type": "text", "id": "secondary_label", "label": "Secondary button label", "default": "Order the $100 Test Kit" },
    { "type": "url", "id": "secondary_link", "label": "Secondary button link" },
    { "type": "image_picker", "id": "image", "label": "Hero image" },
    { "type": "text", "id": "image_alt", "label": "Image alt text", "default": "Finished BlueTex roof and wall install with TermBars" },
    { "type": "text", "id": "image_label", "label": "Image label", "default": "Finished interior · TermBar install" }
  ],
  "blocks": [
    {
      "type": "proof",
      "name": "Proof item",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "Blocks 97% radiant heat" }
      ]
    }
  ],
  "presets": [
    {
      "name": "BlueTex Hero",
      "blocks": [
        { "type": "proof", "settings": { "text": "Blocks 97% radiant heat" } },
        { "type": "proof", "settings": { "text": "Vapor barrier" } },
        { "type": "proof", "settings": { "text": "10× more durable than vinyl" } }
      ]
    }
  ]
}
{% endschema %}

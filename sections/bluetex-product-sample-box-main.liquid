{{ 'component-price.css' | asset_url | stylesheet_tag }}
<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign product_form_id = 'product-form-' | append: section.id
-%}

<section id="BlueTexProductMain-{{ section.id }}" class="bt-pdp-main">
  <div class="bt-pdp-main__grid">
    <div class="bt-pdp-main__gallery">
      <div class="bt-pdp-main__media">
        {%- if product.featured_media -%}
          {%- case product.featured_media.media_type -%}
            {%- when 'image' -%}
              {{ product.featured_media | image_url: width: 1200 | image_tag: loading: 'eager', widths: '500, 800, 1000, 1200', sizes: '(min-width: 990px) 50vw, 100vw', alt: product.featured_media.alt | default: product.title }}
            {%- when 'video' -%}
              {{ product.featured_media | video_tag: controls: true, image_size: '900x' }}
            {%- when 'external_video' -%}
              {{ product.featured_media | external_video_tag }}
            {%- else -%}
              {{ product.featured_media | media_tag }}
          {%- endcase -%}
        {%- else -%}
          <span>{{ section.settings.media_placeholder }}</span>
        {%- endif -%}
        <strong>{{ section.settings.media_badge }}</strong>
      </div>

      {%- if product.media.size > 1 -%}
        <div class="bt-pdp-main__thumbs" aria-label="Product media thumbnails">
          {%- for media in product.media limit: 5 -%}
            <a class="bt-pdp-main__thumb{% if forloop.first %} is-active{% endif %}" href="{{ media.preview_image | image_url: width: 1200 }}">
              {{ media.preview_image | image_url: width: 180 | image_tag: loading: 'lazy', widths: '90, 140, 180', alt: media.alt | default: product.title }}
            </a>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <div class="bt-pdp-main__buy">
      <span class="bt-pdp-main__eyebrow">{{ section.settings.eyebrow }}</span>
      <h1>{{ product.title | default: section.settings.fallback_title }}</h1>
      <p class="bt-pdp-main__subhead">{{ section.settings.subheadline }}</p>

      <div class="bt-pdp-main__price" id="price-{{ section.id }}" role="status">
        {%- render 'price', product: product, use_variant: true, show_badges: false, price_class: 'price--large' -%}
        {%- if section.settings.price_note != blank -%}
          <span>{{ section.settings.price_note }}</span>
        {%- endif -%}
      </div>

      <ul class="bt-pdp-main__bullets">
        {%- for block in section.blocks -%}
          {%- if block.type == 'bullet' -%}
            <li {{ block.shopify_attributes }}>{{ block.settings.text }}</li>
          {%- endif -%}
        {%- endfor -%}
      </ul>

      <product-form class="bt-pdp-main__form" data-section-id="{{ section.id }}">
        <div class="product-form__error-message-wrapper" role="alert" hidden>
          <span class="svg-wrapper">{{- 'icon-error.svg' | inline_asset_content -}}</span>
          <span class="product-form__error-message"></span>
        </div>

        {%- form 'product', product, id: product_form_id, class: 'form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
          {%- unless product.has_only_default_variant -%}
            <label class="bt-pdp-main__label" for="VariantSelect-{{ section.id }}">Option</label>
            <select class="bt-pdp-main__select product-variant-id" id="VariantSelect-{{ section.id }}" name="id">
              {%- for variant in product.variants -%}
                <option
                  value="{{ variant.id }}"
                  {% if variant == current_variant %}selected="selected"{% endif %}
                  {% unless variant.available %}disabled{% endunless %}
                >
                  {{ variant.title }}{% unless variant.available %} - Sold out{% endunless %}
                </option>
              {%- endfor -%}
            </select>
          {%- else -%}
            <input type="hidden" name="id" value="{{ current_variant.id }}" class="product-variant-id">
          {%- endunless -%}

          <div class="bt-pdp-main__qty-row">
            <label class="bt-pdp-main__label" for="Quantity-{{ section.id }}">{{ section.settings.quantity_label }}</label>
            <quantity-input class="quantity bt-pdp-main__qty">
              <button class="quantity__button" name="minus" type="button">
                <span class="visually-hidden">{{ 'products.product.quantity.decrease' | t: product: product.title | escape }}</span>
                <span aria-hidden="true">−</span>
              </button>
              <input
                class="quantity__input"
                type="number"
                name="quantity"
                id="Quantity-{{ section.id }}"
                data-cart-quantity="{{ cart | item_count_for_variant: current_variant.id }}"
                data-min="{{ current_variant.quantity_rule.min }}"
                min="{{ current_variant.quantity_rule.min }}"
                {% if current_variant.quantity_rule.max != null %}max="{{ current_variant.quantity_rule.max }}"{% endif %}
                step="{{ current_variant.quantity_rule.increment }}"
                value="{{ current_variant.quantity_rule.min }}"
                form="{{ product_form_id }}"
              >
              <button class="quantity__button" name="plus" type="button">
                <span class="visually-hidden">{{ 'products.product.quantity.increase' | t: product: product.title | escape }}</span>
                <span aria-hidden="true">+</span>
              </button>
            </quantity-input>
          </div>

          <div class="bt-pdp-main__buttons">
            <button
              id="ProductSubmitButton-{{ section.id }}"
              type="submit"
              name="add"
              class="bt-pdp-main__cart product-form__submit"
              {% unless current_variant.available %}disabled{% endunless %}
            >
              <span>
                {%- if current_variant.available -%}
                  {{ section.settings.add_to_cart_label }}
                {%- else -%}
                  {{ 'products.product.sold_out' | t }}
                {%- endif -%}
              </span>
              {%- render 'loading-spinner' -%}
            </button>
            {%- if section.settings.show_dynamic_checkout -%}
              <div class="bt-pdp-main__dynamic">
                {{ form | payment_button }}
              </div>
            {%- endif -%}
          </div>
        {%- endform -%}
      </product-form>

      {%- if section.settings.quote_label != blank -%}
        <a class="bt-pdp-main__quote" href="{{ section.settings.quote_link }}">{{ section.settings.quote_label }}</a>
      {%- endif -%}

      <div class="bt-pdp-main__trust">
        {%- for block in section.blocks -%}
          {%- if block.type == 'trust' -%}
            <div class="bt-pdp-main__trust-item" {{ block.shopify_attributes }}>
              <span>{{ block.settings.icon }}</span>
              <div><strong>{{ block.settings.heading }}</strong><p>{{ block.settings.text }}</p></div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

<style>
  #BlueTexProductMain-{{ section.id }} { --bt-navy:#0011a7; --bt-navy-hov:#3f62c5; --bt-orange:#ee7f12; --bt-orange-hov:#3f62c5; --bt-ink:#1b1b1b; --bt-text:#1b1b1b; --bt-muted:#535254; --bt-line:#e6e6e7; --bt-soft:#e6e6e7; --bt-grey:#eeeeee; font-family:Lato,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif; background:#fff; padding:34px 0 48px; }
  #BlueTexProductMain-{{ section.id }} * { box-sizing:border-box; }
  #BlueTexProductMain-{{ section.id }} .bt-pdp-main__grid { max-width:1140px; margin:0 auto; padding:0 20px; display:grid; grid-template-columns:1.15fr .85fr; gap:40px; align-items:start; }
  #BlueTexProductMain-{{ section.id }} .bt-pdp-main__media { position:relative; aspect-ratio:1/1; background:var(--bt-grey); border:1px solid var(--bt-soft); border-radius:6px; overflow:hidden; display:flex; align-items:center; justify-content:center; color:var(--bt-navy); font-size:11px; font-weight:700; letter-spacing:1.4px; text-transform:uppercase; }
  #BlueTexProductMain-{{ section.id }} .bt-pdp-main__media img, #BlueTexProductMain-{{ section.id }} .bt-pdp-main__media video, #BlueTexProductMain-{{ section.id }} .bt-pdp-main__media iframe, #BlueTexProductMain-{{ section.id }} .bt-pdp-main__media model-viewer { width:100%; height:100%; object-fit:contain; background:#fff; display:block; }
  #BlueTexProductMain-{{ section.id }} .bt-pdp-main__media strong { position:absolute; top:14px; left:14px; background:var(--bt-orange); color:#fff; border-radius:2px; padding:6px 12px; font-size:11px; font-weight:700; letter-spacing:1.4px; text-transform:uppercase; }
  #BlueTexProductMain-{{ section.id }} .bt-pdp-main__thumbs { display:grid; grid-template-columns:repeat(5,1fr); gap:8px; margin-top:10px; }
  #BlueTexProductMain-{{ section.id }} .bt-pdp-main__thumb { display:block; aspect-ratio:1/1; border:2px solid var(--bt-soft); border-radius:2px; overflow:hidden; background:#fff; }
  #BlueTexProductMain-{{ section.id }} .bt-pdp-main__thumb.is-active, #BlueTexProductMain-{{ section.id }} .bt-pdp-main__thumb:hover { border-color:var(--bt-navy); }
  #BlueTexProductMain-{{ section.id }} .bt-pdp-main__thumb img { width:100%; height:100%; object-fit:cover; display:block; }
  #BlueTexProductMain-{{ section.id }} .bt-pdp-main__eyebrow { display:inline-flex; background:#fef2e4; color:var(--bt-orange-hov); border-left:3px solid var(--bt-orange); border-radius:2px; padding:6px 12px; font-size:11px; font-weight:700; letter-spacing:1.4px; text-transform:uppercase; margin-bottom:14px; }
  #BlueTexProductMain-{{ section.id }} h1 { margin:0 0 10px; color:var(--bt-navy); font-size:30px; line-height:1.1; font-weight:700; letter-spacing:-.2px; text-transform:uppercase; }
  #BlueTexProductMain-{{ section.id }} .bt-pdp-main__subhead { margin:0 0 18px; color:var(--bt-muted); font-size:15px; line-height:1.55; font-weight:500; }
  #BlueTexProductMain-{{ section.id }} .bt-pdp-main__price { display:flex; align-items:baseline; gap:14px; padding:14px 0; margin-bottom:16px; border-top:1px solid var(--bt-soft); border-bottom:1px solid var(--bt-soft); }
  #BlueTexProductMain-{{ section.id }} .bt-pdp-main__price .price { color:var(--bt-ink); font-size:28px; font-weight:700; letter-spacing:-.5px; }
  #BlueTexProductMain-{{ section.id }} .bt-pdp-main__price > span { color:var(--bt-orange-hov); font-size:11px; font-weight:700; letter-spacing:1.2px; text-transform:uppercase; }
  #BlueTexProductMain-{{ section.id }} .bt-pdp-main__bullets { list-style:none; padding:0; margin:0 0 22px; display:grid; gap:9px; }
  #BlueTexProductMain-{{ section.id }} .bt-pdp-main__bullets li { position:relative; padding-left:26px; color:var(--bt-text); font-size:14px; line-height:1.5; }
  #BlueTexProductMain-{{ section.id }} .bt-pdp-main__bullets li:before { content:""; position:absolute; left:0; top:5px; width:14px; height:14px; background:var(--bt-orange); border-radius:2px; }
  #BlueTexProductMain-{{ section.id }} .bt-pdp-main__bullets li:after { content:"✓"; position:absolute; left:2px; top:1px; color:#fff; font-size:11px; font-weight:700; }
  #BlueTexProductMain-{{ section.id }} .bt-pdp-main__label { display:block; color:var(--bt-muted); font-size:12px; font-weight:700; letter-spacing:1.2px; text-transform:uppercase; margin-bottom:7px; }
  #BlueTexProductMain-{{ section.id }} .bt-pdp-main__select { width:100%; min-height:44px; border:2px solid var(--bt-line); border-radius:2px; background:#fff; color:var(--bt-ink); font:600 14px Lato, sans-serif; padding:0 12px; margin-bottom:14px; }
  #BlueTexProductMain-{{ section.id }} .bt-pdp-main__qty-row { display:flex; align-items:center; gap:14px; margin-bottom:14px; }
  #BlueTexProductMain-{{ section.id }} .bt-pdp-main__qty { min-height:42px; border:2px solid var(--bt-line); border-radius:2px; }
  #BlueTexProductMain-{{ section.id }} .bt-pdp-main__qty:before, #BlueTexProductMain-{{ section.id }} .bt-pdp-main__qty:after { display:none; }
  #BlueTexProductMain-{{ section.id }} .quantity__button { color:var(--bt-navy); font-weight:700; }
  #BlueTexProductMain-{{ section.id }} .bt-pdp-main__buttons { display:grid; gap:8px; margin-bottom:12px; }
  #BlueTexProductMain-{{ section.id }} .bt-pdp-main__cart, #BlueTexProductMain-{{ section.id }} .bt-pdp-main__quote { width:100%; min-height:52px; display:inline-flex; align-items:center; justify-content:center; border-radius:4px; border:2px solid var(--bt-navy); background:var(--bt-navy); color:#fff; font-size:14px; font-weight:700; letter-spacing:.8px; text-transform:uppercase; text-decoration:none; cursor:pointer; }
  #BlueTexProductMain-{{ section.id }} .bt-pdp-main__cart:hover, #BlueTexProductMain-{{ section.id }} .bt-pdp-main__quote:hover { background:var(--bt-navy-hov); border-color:var(--bt-navy-hov); }
  #BlueTexProductMain-{{ section.id }} .bt-pdp-main__cart[disabled] { opacity:.5; cursor:not-allowed; }
  #BlueTexProductMain-{{ section.id }} .bt-pdp-main__dynamic .shopify-payment-button__button { border-radius:4px; min-height:50px; font-family:Lato,sans-serif; font-weight:700; text-transform:uppercase; letter-spacing:.7px; }
  #BlueTexProductMain-{{ section.id }} .bt-pdp-main__quote { background:var(--bt-navy); border-color:var(--bt-navy); margin-bottom:18px; }
  #BlueTexProductMain-{{ section.id }} .bt-pdp-main__quote:hover { background:var(--bt-navy-hov); border-color:var(--bt-navy-hov); }
  #BlueTexProductMain-{{ section.id }} .bt-pdp-main__trust { display:grid; grid-template-columns:1fr 1fr; gap:10px; }
  #BlueTexProductMain-{{ section.id }} .bt-pdp-main__trust-item { display:flex; gap:10px; align-items:flex-start; background:var(--bt-grey); border:1px solid var(--bt-soft); border-radius:2px; padding:10px 12px; }
  #BlueTexProductMain-{{ section.id }} .bt-pdp-main__trust-item > span { width:30px; height:30px; flex:0 0 30px; display:flex; align-items:center; justify-content:center; background:#fff; color:var(--bt-navy); border-left:3px solid var(--bt-orange); border-radius:2px; font-size:14px; font-weight:700; }
  #BlueTexProductMain-{{ section.id }} .bt-pdp-main__trust-item strong { display:block; color:var(--bt-ink); font-size:12px; font-weight:700; letter-spacing:.6px; text-transform:uppercase; margin-bottom:1px; }
  #BlueTexProductMain-{{ section.id }} .bt-pdp-main__trust-item p { margin:0; color:var(--bt-muted); font-size:12px; line-height:1.35; }
  @media (max-width: 990px) { #BlueTexProductMain-{{ section.id }} .bt-pdp-main__grid { grid-template-columns:1fr; gap:28px; } }
  @media (max-width: 620px) { #BlueTexProductMain-{{ section.id }} { padding:28px 0 34px; } #BlueTexProductMain-{{ section.id }} .bt-pdp-main__grid { padding:0 16px; } #BlueTexProductMain-{{ section.id }} h1 { font-size:24px; } #BlueTexProductMain-{{ section.id }} .bt-pdp-main__trust { grid-template-columns:1fr; } #BlueTexProductMain-{{ section.id }} .bt-pdp-main__price { flex-direction:column; gap:4px; align-items:flex-start; } }
</style>

{% schema %}
{
  "name": "BlueTex Sample Box Main",
  "settings": [
    { "type": "text", "id": "media_badge", "label": "Media badge", "default": "$100 Test Kit" },
    { "type": "text", "id": "media_placeholder", "label": "Media placeholder", "default": "Product media" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "★ Try Before You Commit" },
    { "type": "text", "id": "fallback_title", "label": "Fallback title", "default": "BlueTex™ Cover/Repair System Sample Box" },
    { "type": "textarea", "id": "subheadline", "label": "Subheadline", "default": "Full-size pieces of every part of the system so you can test the install on one section of your metal building before ordering full rolls." },
    { "type": "text", "id": "price_note", "label": "Price note", "default": "Fully redeemable on a $500+ order" },
    { "type": "text", "id": "quantity_label", "label": "Quantity label", "default": "Quantity" },
    { "type": "text", "id": "add_to_cart_label", "label": "Add to cart label", "default": "Order the Sample Box — $100" },
    { "type": "checkbox", "id": "show_dynamic_checkout", "label": "Show dynamic checkout button", "default": true },
    { "type": "text", "id": "quote_label", "label": "Quote button label", "default": "Send Photos for a Full-Building Quote" },
    { "type": "url", "id": "quote_link", "label": "Quote button link" }
  ],
  "blocks": [
    {
      "type": "bullet",
      "name": "Bullet",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "20 ft of BlueTex™ 2mm Pro 50″ — the same product used on full-building cover and repair installs" }
      ]
    },
    {
      "type": "trust",
      "name": "Trust block",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon text", "default": "$" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Risk-Free Trial" },
        { "type": "text", "id": "text", "label": "Text", "default": "$100 credited back on any order of $500 or more." }
      ]
    }
  ],
  "presets": [
    {
      "name": "BlueTex Sample Box Main",
      "blocks": [
        { "type": "bullet", "settings": { "text": "20 ft of BlueTex™ 2mm Pro 50″ — the same product used on full-building cover and repair installs" } },
        { "type": "bullet", "settings": { "text": "4 aluminum TermBars (48″) and the 1″ #10 hex screws to fasten them" } },
        { "type": "bullet", "settings": { "text": "30 ft of 3″ white vapor barrier seam tape for sealing the panels" } },
        { "type": "bullet", "settings": { "text": "Sample EasyClips for testing roofline attachment on red iron buildings" } },
        { "type": "bullet", "settings": { "text": "Show owners, tenants, or management exactly how the finished panel looks" } },
        { "type": "trust", "settings": { "icon": "$", "heading": "Risk-Free Trial", "text": "$100 credited back on any order of $500 or more." } },
        { "type": "trust", "settings": { "icon": "↓", "heading": "Free Shipping", "text": "Ships free in the contiguous USA." } },
        { "type": "trust", "settings": { "icon": "★", "heading": "Full-Size Materials", "text": "Real product, not swatches. Test it on the building." } },
        { "type": "trust", "settings": { "icon": "☎", "heading": "Real Person on the Phone", "text": "1-800-595-8772 — we help you size up the order." } }
      ]
    }
  ]
}
{% endschema %}

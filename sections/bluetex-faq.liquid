<section id="BlueTexFaq-{{ section.id }}" class="bt-faq">
  <div class="bt-faq__container">
    <div class="bt-faq__label">
      <span>{{ section.settings.heading }}</span>
      {%- if section.settings.link_label != blank -%}<a href="{{ section.settings.link }}">{{ section.settings.link_label }}</a>{%- endif -%}
    </div>
    <div class="bt-faq__grid">
      {%- for block in section.blocks -%}
        <article class="bt-faq__card{% if block.settings.featured %} bt-faq__card--featured{% endif %}" {{ block.shopify_attributes }}>
          <h3>{{ block.settings.question }}</h3>
          <p>{{ block.settings.answer }}</p>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  #BlueTexFaq-{{ section.id }} { --bt-navy:#0011a7; --bt-orange:#ee7f12; --bt-ink:#1b1b1b; --bt-text:#1b1b1b; --bt-soft:#e6e6e7; --bt-grey:#eeeeee; font-family:Lato,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif; background:#fff; padding:44px 0; }
  #BlueTexFaq-{{ section.id }} * { box-sizing:border-box; }
  #BlueTexFaq-{{ section.id }} .bt-faq__container { max-width:1140px; margin:0 auto; padding:0 20px; }
  #BlueTexFaq-{{ section.id }} .bt-faq__label { background:#e6e6e6; border-left:4px solid var(--bt-navy); padding:14px 22px; display:flex; align-items:center; justify-content:space-between; gap:12px; color:var(--bt-ink); font-size:18px; line-height:1.2; font-weight:700; letter-spacing:1.4px; text-transform:uppercase; }
  #BlueTexFaq-{{ section.id }} .bt-faq__label a { color:var(--bt-navy); font-size:12px; font-weight:700; letter-spacing:.8px; text-decoration:none; white-space:nowrap; }
  #BlueTexFaq-{{ section.id }} .bt-faq__label a:hover { color:var(--bt-orange); }
  #BlueTexFaq-{{ section.id }} .bt-faq__grid { display:grid; grid-template-columns:repeat(3,1fr); gap:16px; margin-top:18px; }
  #BlueTexFaq-{{ section.id }} .bt-faq__card { background:var(--bt-grey); border:1px solid var(--bt-soft); border-left:4px solid var(--bt-orange); border-radius:2px; padding:22px; }
  #BlueTexFaq-{{ section.id }} .bt-faq__card--featured { border-left-color:var(--bt-navy); background:#fff; }
  #BlueTexFaq-{{ section.id }} .bt-faq__card h3 { margin:0 0 8px; color:var(--bt-navy); font-size:15px; line-height:1.25; font-weight:700; letter-spacing:.4px; text-transform:uppercase; }
  #BlueTexFaq-{{ section.id }} .bt-faq__card p { margin:0; color:var(--bt-text); font-size:14px; line-height:1.5; }
  @media (max-width: 900px) { #BlueTexFaq-{{ section.id }} .bt-faq__grid { grid-template-columns:1fr; } }
  @media (max-width: 560px) { #BlueTexFaq-{{ section.id }} { padding:32px 0; } #BlueTexFaq-{{ section.id }} .bt-faq__container { padding:0 16px; } #BlueTexFaq-{{ section.id }} .bt-faq__label { align-items:flex-start; flex-direction:column; } }
</style>

{% schema %}
{
  "name": "BlueTex FAQ",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Common TermBar Questions" },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "View Full FAQ →" },
    { "type": "url", "id": "link", "label": "Link" }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "Question",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "Is It Strong?" },
        { "type": "textarea", "id": "answer", "label": "Answer", "default": "Yes. TermBars mechanically fasten the material to the building frame. The finished wall is tighter and more durable than the original metal building insulation it covers." },
        { "type": "checkbox", "id": "featured", "label": "Use navy accent", "default": false }
      ]
    }
  ],
  "presets": [
    {
      "name": "BlueTex FAQ",
      "blocks": [
        { "type": "question", "settings": { "question": "Is It Strong?", "answer": "Yes. TermBars mechanically fasten the material to the building frame. The finished wall is tighter and more durable than the original metal building insulation it covers.", "featured": true } },
        { "type": "question", "settings": { "question": "Can You Paint It?", "answer": "Yes. BlueTex and the TermBars both hold paint. Most customers leave it bright white for light reflection, but you can roll or spray latex paint for a custom color." } },
        { "type": "question", "settings": { "question": "Do I Have to Tear Out the Old Insulation?", "answer": "Usually no. BlueTex is commonly installed over existing insulation. The TermBar presses the old material in place and the new BlueTex creates the finished interior." } }
      ]
    }
  ]
}
{% endschema %}

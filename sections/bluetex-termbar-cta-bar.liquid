<section id="BlueTexTermbarCtaBar-{{ section.id }}" class="bt-tbcta">
  <div class="bt-tbcta__inner">
    <div class="bt-tbcta__copy">
      {%- if section.settings.eyebrow != blank -%}
        <span class="bt-tbcta__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2>{{ section.settings.heading }}</h2>
      {%- if section.settings.text != blank -%}
        <p>{{ section.settings.text }}</p>
      {%- endif -%}
    </div>
    <div class="bt-tbcta__actions">
      {%- if section.settings.cta1_label != blank -%}
        <a class="bt-tbcta__btn bt-tbcta__btn--ghost" href="{{ section.settings.cta1_link }}">{{ section.settings.cta1_label }}</a>
      {%- endif -%}
      {%- if section.settings.cta2_label != blank -%}
        <a class="bt-tbcta__btn bt-tbcta__btn--white" href="{{ section.settings.cta2_link }}">{{ section.settings.cta2_label }}</a>
      {%- endif -%}
      {%- if section.settings.cta3_label != blank -%}
        <a class="bt-tbcta__btn bt-tbcta__btn--orange" href="{{ section.settings.cta3_link }}">{{ section.settings.cta3_label }}</a>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  #BlueTexTermbarCtaBar-{{ section.id }} { --bt-navy:#0011a7; --bt-deep:#002f6c; --bt-orange:#ee7f12; --bt-orange-hov:#d56f0d; font-family:Lato,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif; background:#eeeeee; padding:40px 20px 56px; }
  #BlueTexTermbarCtaBar-{{ section.id }} * { box-sizing:border-box; }
  #BlueTexTermbarCtaBar-{{ section.id }} .bt-tbcta__inner { max-width:1140px; margin:0 auto; background:#002f6c; color:#fff; border-left:6px solid var(--bt-navy); border-radius:2px; padding:34px 38px; display:grid; grid-template-columns:1.2fr auto; gap:28px; align-items:center; }
  #BlueTexTermbarCtaBar-{{ section.id }} .bt-tbcta__eyebrow { display:block; color:#ffcf9c; font-size:11px; font-weight:700; letter-spacing:1.5px; text-transform:uppercase; margin-bottom:8px; }
  #BlueTexTermbarCtaBar-{{ section.id }} h2 { margin:0 0 8px; color:#fff; font-size:24px; line-height:1.12; font-weight:700; letter-spacing:.2px; text-transform:uppercase; }
  #BlueTexTermbarCtaBar-{{ section.id }} .bt-tbcta__copy p { margin:0; color:#e0e4f0; font-size:15px; line-height:1.55; max-width:580px; }
  #BlueTexTermbarCtaBar-{{ section.id }} .bt-tbcta__actions { display:flex; gap:10px; flex-wrap:wrap; justify-content:flex-end; }
  #BlueTexTermbarCtaBar-{{ section.id }} .bt-tbcta__btn { display:inline-flex; justify-content:center; align-items:center; padding:15px 22px; border-radius:4px; border:2px solid transparent; font-size:13px; font-weight:700; letter-spacing:.8px; text-transform:uppercase; text-decoration:none; white-space:nowrap; transition:background .12s ease,border-color .12s ease,color .12s ease; }
  #BlueTexTermbarCtaBar-{{ section.id }} .bt-tbcta__btn--ghost { background:transparent; color:#fff; border-color:rgba(255,255,255,.55); }
  #BlueTexTermbarCtaBar-{{ section.id }} .bt-tbcta__btn--ghost:hover { background:rgba(255,255,255,.1); border-color:#fff; }
  #BlueTexTermbarCtaBar-{{ section.id }} .bt-tbcta__btn--white { background:#fff; color:var(--bt-navy); border-color:#fff; }
  #BlueTexTermbarCtaBar-{{ section.id }} .bt-tbcta__btn--white:hover { background:#eeeeee; border-color:#eeeeee; }
  #BlueTexTermbarCtaBar-{{ section.id }} .bt-tbcta__btn--orange { background:var(--bt-orange); color:#fff; border-color:var(--bt-orange); }
  #BlueTexTermbarCtaBar-{{ section.id }} .bt-tbcta__btn--orange:hover { background:var(--bt-orange-hov); border-color:var(--bt-orange-hov); }
  @media (max-width: 990px) { #BlueTexTermbarCtaBar-{{ section.id }} .bt-tbcta__inner { grid-template-columns:1fr; padding:30px 28px; } #BlueTexTermbarCtaBar-{{ section.id }} .bt-tbcta__actions { justify-content:flex-start; } }
  @media (max-width: 560px) { #BlueTexTermbarCtaBar-{{ section.id }} { padding:32px 16px; } #BlueTexTermbarCtaBar-{{ section.id }} .bt-tbcta__inner { padding:28px 22px; } #BlueTexTermbarCtaBar-{{ section.id }} .bt-tbcta__btn { width:100%; } }
</style>

{% schema %}
{
  "name": "BlueTex TermBar CTA Bar",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Next Step" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Get the Plan, Try It on Your Building, or Send Us Photos" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Three ways to move forward — read the full install guide, order the $100 test kit to try BlueTex on your building, or send photos and dimensions for a quote." },
    { "type": "header", "content": "CTA 1 (left, ghost)" },
    { "type": "text", "id": "cta1_label", "label": "Label", "default": "Complete Install Guide" },
    { "type": "url", "id": "cta1_link", "label": "Link" },
    { "type": "header", "content": "CTA 2 (middle, white)" },
    { "type": "text", "id": "cta2_label", "label": "Label", "default": "Order a $100 Test Kit" },
    { "type": "url", "id": "cta2_link", "label": "Link" },
    { "type": "header", "content": "CTA 3 (right, orange — primary)" },
    { "type": "text", "id": "cta3_label", "label": "Label", "default": "Request a Quote" },
    { "type": "url", "id": "cta3_link", "label": "Link" }
  ],
  "presets": [
    { "name": "BlueTex TermBar CTA Bar" }
  ]
}
{% endschema %}

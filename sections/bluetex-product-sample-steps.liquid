<section id="BlueTexSampleSteps-{{ section.id }}" class="bt-sample-steps">
  <div class="bt-sample-steps__container">
    <div class="bt-sample-steps__label">
      <span>{{ section.settings.heading }}</span>
      {%- if section.settings.link_label != blank -%}<a href="{{ section.settings.link }}">{{ section.settings.link_label }}</a>{%- endif -%}
    </div>
    <div class="bt-sample-steps__grid">
      {%- for block in section.blocks -%}
        <article class="bt-sample-steps__card" {{ block.shopify_attributes }}>
          <span>{{ block.settings.step }}</span>
          <h3>{{ block.settings.heading }}</h3>
          <p>{{ block.settings.text }}</p>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  #BlueTexSampleSteps-{{ section.id }} { --bt-navy:#0011a7; --bt-orange:#ee7f12; --bt-ink:#1b1b1b; --bt-text:#1b1b1b; --bt-soft:#e6e6e7; --bt-grey:#eeeeee; font-family:Lato,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif; background:#fff; padding:48px 0; }
  #BlueTexSampleSteps-{{ section.id }} * { box-sizing:border-box; }
  #BlueTexSampleSteps-{{ section.id }} .bt-sample-steps__container { max-width:1140px; margin:0 auto; padding:0 20px; }
  #BlueTexSampleSteps-{{ section.id }} .bt-sample-steps__label { background:#e6e6e6; border-left:4px solid var(--bt-navy); padding:14px 22px; display:flex; align-items:center; justify-content:space-between; gap:12px; color:var(--bt-ink); font-size:18px; font-weight:700; letter-spacing:1.4px; line-height:1.2; text-transform:uppercase; }
  #BlueTexSampleSteps-{{ section.id }} .bt-sample-steps__label a { color:var(--bt-navy); font-size:12px; font-weight:700; letter-spacing:.8px; text-decoration:none; white-space:nowrap; }
  #BlueTexSampleSteps-{{ section.id }} .bt-sample-steps__label a:hover { color:var(--bt-orange); }
  #BlueTexSampleSteps-{{ section.id }} .bt-sample-steps__grid { display:grid; grid-template-columns:repeat(4,1fr); gap:14px; margin-top:18px; }
  #BlueTexSampleSteps-{{ section.id }} .bt-sample-steps__card { background:var(--bt-grey); border-top:4px solid var(--bt-navy); border-radius:2px; padding:22px 20px 24px; }
  #BlueTexSampleSteps-{{ section.id }} .bt-sample-steps__card:nth-child(3) { border-top-color:var(--bt-orange); }
  #BlueTexSampleSteps-{{ section.id }} .bt-sample-steps__card span { color:var(--bt-orange); font-size:11px; font-weight:700; letter-spacing:1.6px; text-transform:uppercase; }
  #BlueTexSampleSteps-{{ section.id }} .bt-sample-steps__card h3 { margin:6px 0; color:var(--bt-navy); font-size:16px; font-weight:700; letter-spacing:.4px; text-transform:uppercase; line-height:1.2; }
  #BlueTexSampleSteps-{{ section.id }} .bt-sample-steps__card p { margin:0; color:var(--bt-text); font-size:14px; line-height:1.5; }
  @media (max-width: 900px) { #BlueTexSampleSteps-{{ section.id }} .bt-sample-steps__grid { grid-template-columns:repeat(2,1fr); } }
  @media (max-width: 560px) { #BlueTexSampleSteps-{{ section.id }} { padding:32px 0; } #BlueTexSampleSteps-{{ section.id }} .bt-sample-steps__container { padding:0 16px; } #BlueTexSampleSteps-{{ section.id }} .bt-sample-steps__grid { grid-template-columns:1fr; } #BlueTexSampleSteps-{{ section.id }} .bt-sample-steps__label { align-items:flex-start; flex-direction:column; } }
</style>

{% schema %}
{
  "name": "BlueTex Sample Steps",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "How To Use the Sample Box" },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "View Full Install Guide →" },
    { "type": "url", "id": "link", "label": "Link" }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "text", "id": "step", "label": "Step label", "default": "01 · Pick a Section" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Pick a Section" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Choose one bay or one section of wall on your metal building to test the cover/repair system." }
      ]
    }
  ],
  "presets": [
    {
      "name": "BlueTex Sample Steps",
      "blocks": [
        { "type": "step", "settings": { "step": "01 · Pick a Section", "heading": "Pick a Section", "text": "Choose one bay or one section of wall on your metal building to test the cover/repair system." } },
        { "type": "step", "settings": { "step": "02 · Install a TermBar Run", "heading": "Install a TermBar Run", "text": "Roll out the 20 ft of 50-inch 2mm Pro and fasten it with the included aluminum TermBars and #10 hex screws." } },
        { "type": "step", "settings": { "step": "03 · Tape the Seam", "heading": "Tape the Seam", "text": "Use the 3-inch white vapor barrier tape to seal the seam and lock in the vapor barrier." } },
        { "type": "step", "settings": { "step": "04 · Send Us Photos", "heading": "Send Us Photos", "text": "Snap a few photos and your building dimensions and we'll build a full-building material list and quote." } }
      ]
    }
  ]
}
{% endschema %}

<section id="BlueTexTermbarProblem-{{ section.id }}" class="bt-tbproblem">
  <div class="bt-tbproblem__wrap">
    <div class="bt-tbproblem__head">
      {%- if section.settings.eyebrow != blank -%}
        <span class="bt-tbproblem__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.lead }}</p>
    </div>
    <ol class="bt-tbproblem__steps">
      {%- for block in section.blocks -%}
        <li {{ block.shopify_attributes }}>
          <span class="bt-tbproblem__num">{{ forloop.index }}</span>
          <div>
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.text }}</p>
          </div>
        </li>
      {%- endfor -%}
    </ol>
  </div>
</section>

<style>
  #BlueTexTermbarProblem-{{ section.id }} { --bt-navy:#0011a7; --bt-deep:#002f6c; --bt-orange:#ee7f12; --bt-text:#1b1b1b; --bt-muted:#535254; --bt-soft:#e6e6e7; font-family:Lato,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif; background:#fff; padding:56px 20px; border-top:1px solid var(--bt-soft); }
  #BlueTexTermbarProblem-{{ section.id }} * { box-sizing:border-box; }
  #BlueTexTermbarProblem-{{ section.id }} .bt-tbproblem__wrap { max-width:1140px; margin:0 auto; }
  #BlueTexTermbarProblem-{{ section.id }} .bt-tbproblem__head { max-width:760px; margin:0 0 28px; }
  #BlueTexTermbarProblem-{{ section.id }} .bt-tbproblem__eyebrow { display:inline-block; background:var(--bt-orange); color:#fff; font-size:11px; font-weight:700; letter-spacing:1.6px; text-transform:uppercase; padding:5px 12px; border-radius:2px; margin-bottom:12px; }
  #BlueTexTermbarProblem-{{ section.id }} h2 { margin:0 0 10px; color:var(--bt-navy); font-size:30px; line-height:1.1; font-weight:700; letter-spacing:.2px; text-transform:uppercase; }
  #BlueTexTermbarProblem-{{ section.id }} .bt-tbproblem__head p { margin:0; color:var(--bt-text); font-size:16px; line-height:1.55; }
  #BlueTexTermbarProblem-{{ section.id }} .bt-tbproblem__steps { list-style:none; margin:0; padding:0; display:grid; grid-template-columns:repeat(3,1fr); gap:16px; }
  #BlueTexTermbarProblem-{{ section.id }} .bt-tbproblem__steps li { display:flex; gap:14px; padding:22px; border:1px solid var(--bt-soft); border-radius:4px; background:#fff; }
  #BlueTexTermbarProblem-{{ section.id }} .bt-tbproblem__num { flex:0 0 auto; width:32px; height:32px; border-radius:2px; background:var(--bt-navy); color:#fff; display:flex; align-items:center; justify-content:center; font-size:14px; font-weight:700; }
  #BlueTexTermbarProblem-{{ section.id }} .bt-tbproblem__steps h3 { margin:0 0 6px; color:var(--bt-deep); font-size:15px; line-height:1.2; font-weight:700; letter-spacing:.4px; text-transform:uppercase; }
  #BlueTexTermbarProblem-{{ section.id }} .bt-tbproblem__steps p { margin:0; color:var(--bt-muted); font-size:14px; line-height:1.55; }
  @media (max-width: 860px) { #BlueTexTermbarProblem-{{ section.id }} .bt-tbproblem__steps { grid-template-columns:1fr; } #BlueTexTermbarProblem-{{ section.id }} h2 { font-size:24px; } }
  @media (max-width: 560px) { #BlueTexTermbarProblem-{{ section.id }} { padding:40px 16px; } }
</style>

{% schema %}
{
  "name": "BlueTex TermBar Problem",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The Problem" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Why Old Insulation Goes Wet, Sagging, and Stained" },
    { "type": "textarea", "id": "lead", "label": "Lead text", "default": "Builder-grade vinyl vapor barriers fail within a few years. Once they tear or pull away from the purlins, warm interior moisture moves freely through the fiberglass and condenses on the cold metal roof and walls. The fiberglass soaks it up, sags under the weight, and leaves behind the brown stains and torn liner you see today." }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "textarea", "id": "text", "label": "Text" }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "BlueTex TermBar Problem",
      "blocks": [
        { "type": "step", "settings": { "title": "Vapor Barrier Fails", "text": "The original white vinyl liner tears at fasteners, pulls away at seams, and stops sealing — usually within 5 to 10 years of install." } },
        { "type": "step", "settings": { "title": "Moisture Hits the Fiberglass", "text": "Warm interior air carries moisture through the failed barrier and into the fiberglass blanket, which soaks it up like a sponge." } },
        { "type": "step", "settings": { "title": "Condensation on Cold Metal", "text": "Moisture condenses against the cold roof and wall panels, drips back into the insulation, and leaves the sagging, stained mess you see today." } }
      ]
    }
  ]
}
{% endschema %}

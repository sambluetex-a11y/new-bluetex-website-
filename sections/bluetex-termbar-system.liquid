<section id="BlueTexTermbar-{{ section.id }}" class="bt-termbar">
  <div class="bt-termbar__head">
    <div>
      <span class="bt-termbar__badge">{{ section.settings.badge }}</span>
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.text }}</p>
    </div>
    <div class="bt-termbar__actions">
      {%- if section.settings.primary_label != blank -%}<a class="bt-termbar__btn bt-termbar__btn--navy" href="{{ section.settings.primary_link }}">{{ section.settings.primary_label }}</a>{%- endif -%}
      {%- if section.settings.secondary_label != blank -%}<a class="bt-termbar__btn bt-termbar__btn--outline" href="{{ section.settings.secondary_link }}">{{ section.settings.secondary_label }}</a>{%- endif -%}
    </div>
  </div>

  <div class="bt-termbar__media">
    <div class="bt-termbar__main-image">
      {%- if section.settings.main_image != blank -%}
        {{ section.settings.main_image | image_url: width: 1000 | image_tag: loading: 'lazy', widths: '500, 800, 1000', sizes: '(min-width: 990px) 55vw, 100vw', alt: section.settings.main_image_alt }}
      {%- else -%}
        <span>Add installed TermBar detail</span>
      {%- endif -%}
      <strong>{{ section.settings.main_image_label }}</strong>
    </div>
    <div class="bt-termbar__tiles">
      {%- for block in section.blocks -%}
        {%- if block.type == 'image_tile' -%}
          <div class="bt-termbar__tile" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', widths: '300, 450, 600', sizes: '(min-width: 990px) 22vw, 50vw', alt: block.settings.alt }}
            {%- else -%}
              <span>{{ block.settings.label }}</span>
            {%- endif -%}
            <strong>{{ block.settings.label }}</strong>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  <div class="bt-termbar__cards">
    {%- for block in section.blocks -%}
      {%- if block.type == 'card' -%}
        <div class="bt-termbar__card{% if block.settings.accent %} bt-termbar__card--accent{% endif %}" {{ block.shopify_attributes }}>
          <span>{{ block.settings.step }}</span>
          <h3>{{ block.settings.heading }}</h3>
          <p>{{ block.settings.text }}</p>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>

<style>
  #BlueTexTermbar-{{ section.id }} { --bt-navy:#0011a7; --bt-navy-hov:#3f62c5; --bt-orange:#ee7f12; --bt-orange-hov:#3f62c5; --bt-ink:#1b1b1b; --bt-text:#1b1b1b; --bt-muted:#535254; --bt-line:#e6e6e7; --bt-soft:#e6e6e7; --bt-grey:#eeeeee; font-family:Lato,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif; background:#fff; padding:54px 0; }
  #BlueTexTermbar-{{ section.id }} * { box-sizing:border-box; }
  #BlueTexTermbar-{{ section.id }} .bt-termbar__head, #BlueTexTermbar-{{ section.id }} .bt-termbar__media, #BlueTexTermbar-{{ section.id }} .bt-termbar__cards { max-width:1140px; margin-left:auto; margin-right:auto; padding-left:20px; padding-right:20px; }
  #BlueTexTermbar-{{ section.id }} .bt-termbar__head { display:grid; grid-template-columns:1.3fr 1fr; gap:32px; align-items:end; margin-bottom:26px; }
  #BlueTexTermbar-{{ section.id }} .bt-termbar__badge { display:inline-flex; background:#fef2e4; color:var(--bt-orange-hov); border-left:3px solid var(--bt-orange); border-radius:2px; padding:6px 12px; font-size:11px; font-weight:700; letter-spacing:1.4px; text-transform:uppercase; margin-bottom:10px; }
  #BlueTexTermbar-{{ section.id }} h2 { margin:0 0 8px; color:var(--bt-navy); font-size:30px; line-height:1.1; font-weight:700; letter-spacing:.2px; text-transform:uppercase; }
  #BlueTexTermbar-{{ section.id }} .bt-termbar__head p { margin:0; color:var(--bt-text); font-size:16px; line-height:1.55; }
  #BlueTexTermbar-{{ section.id }} .bt-termbar__actions { display:flex; justify-content:flex-end; gap:10px; flex-wrap:wrap; }
  #BlueTexTermbar-{{ section.id }} .bt-termbar__btn { display:inline-flex; align-items:center; justify-content:center; padding:13px 22px; border-radius:4px; border:2px solid var(--bt-navy); font-size:13px; font-weight:700; letter-spacing:.8px; text-transform:uppercase; text-decoration:none; }
  #BlueTexTermbar-{{ section.id }} .bt-termbar__btn--navy { color:#fff; background:var(--bt-navy); }
  #BlueTexTermbar-{{ section.id }} .bt-termbar__btn--navy:hover { background:var(--bt-navy-hov); border-color:var(--bt-navy-hov); }
  #BlueTexTermbar-{{ section.id }} .bt-termbar__btn--outline { color:var(--bt-navy); background:#fff; }
  #BlueTexTermbar-{{ section.id }} .bt-termbar__btn--outline:hover { color:#fff; background:var(--bt-navy); }
  #BlueTexTermbar-{{ section.id }} .bt-termbar__media { display:grid; grid-template-columns:1.15fr .85fr; gap:24px; align-items:stretch; }
  #BlueTexTermbar-{{ section.id }} .bt-termbar__main-image, #BlueTexTermbar-{{ section.id }} .bt-termbar__tile { position:relative; overflow:hidden; border:1px solid var(--bt-line); background:#ddd; border-radius:2px; display:flex; align-items:center; justify-content:center; color:var(--bt-navy); font-size:11px; font-weight:700; letter-spacing:1.4px; text-transform:uppercase; }
  #BlueTexTermbar-{{ section.id }} .bt-termbar__main-image { aspect-ratio:4/3; border-radius:6px; }
  #BlueTexTermbar-{{ section.id }} .bt-termbar__main-image img, #BlueTexTermbar-{{ section.id }} .bt-termbar__tile img { width:100%; height:100%; object-fit:cover; display:block; }
  #BlueTexTermbar-{{ section.id }} .bt-termbar__main-image strong, #BlueTexTermbar-{{ section.id }} .bt-termbar__tile strong { position:absolute; left:10px; bottom:10px; color:#fff; background:rgba(18,32,92,.9); border-radius:2px; padding:5px 10px; font-size:10px; font-weight:700; letter-spacing:1.2px; text-transform:uppercase; }
  #BlueTexTermbar-{{ section.id }} .bt-termbar__main-image strong { left:12px; bottom:12px; font-size:11px; }
  #BlueTexTermbar-{{ section.id }} .bt-termbar__tiles { display:grid; grid-template-columns:1fr 1fr; gap:8px; }
  #BlueTexTermbar-{{ section.id }} .bt-termbar__tile { aspect-ratio:4/3; }
  #BlueTexTermbar-{{ section.id }} .bt-termbar__cards { margin-top:28px; display:grid; grid-template-columns:repeat(4,1fr); gap:14px; }
  #BlueTexTermbar-{{ section.id }} .bt-termbar__card { background:var(--bt-grey); border-top:4px solid var(--bt-navy); border-radius:2px; padding:22px 20px 24px; }
  #BlueTexTermbar-{{ section.id }} .bt-termbar__card--accent { border-top-color:var(--bt-orange); }
  #BlueTexTermbar-{{ section.id }} .bt-termbar__card span { color:var(--bt-orange); font-size:11px; font-weight:700; letter-spacing:1.6px; text-transform:uppercase; }
  #BlueTexTermbar-{{ section.id }} .bt-termbar__card h3 { margin:6px 0 6px; color:var(--bt-navy); font-size:16px; line-height:1.2; font-weight:700; letter-spacing:.4px; text-transform:uppercase; }
  #BlueTexTermbar-{{ section.id }} .bt-termbar__card p { margin:0; color:var(--bt-text); font-size:14px; line-height:1.5; }
  @media (max-width: 990px) { #BlueTexTermbar-{{ section.id }} .bt-termbar__head, #BlueTexTermbar-{{ section.id }} .bt-termbar__media { grid-template-columns:1fr; } #BlueTexTermbar-{{ section.id }} .bt-termbar__actions { justify-content:flex-start; } #BlueTexTermbar-{{ section.id }} .bt-termbar__cards { grid-template-columns:repeat(2,1fr); } }
  @media (max-width: 560px) { #BlueTexTermbar-{{ section.id }} { padding:32px 0; } #BlueTexTermbar-{{ section.id }} .bt-termbar__head, #BlueTexTermbar-{{ section.id }} .bt-termbar__media, #BlueTexTermbar-{{ section.id }} .bt-termbar__cards { padding-left:16px; padding-right:16px; } #BlueTexTermbar-{{ section.id }} .bt-termbar__cards { grid-template-columns:1fr; } #BlueTexTermbar-{{ section.id }} h2 { font-size:23px; } }
</style>

{% schema %}
{
  "name": "BlueTex TermBar System",
  "settings": [
    { "type": "text", "id": "badge", "label": "Badge", "default": "★ Most Popular Install Method" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The TermBar System Is the Main BlueTex Install Method" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "TermBars fasten BlueTex to the purlins and girts so the finished surface stays tight, flat, and clean." },
    { "type": "image_picker", "id": "main_image", "label": "Main image" },
    { "type": "text", "id": "main_image_alt", "label": "Main image alt", "default": "Installed TermBar detail on BlueTex wall" },
    { "type": "text", "id": "main_image_label", "label": "Main image label", "default": "Installed TermBar Detail" },
    { "type": "text", "id": "primary_label", "label": "Primary button label", "default": "View Install Guide" },
    { "type": "url", "id": "primary_link", "label": "Primary button link" },
    { "type": "text", "id": "secondary_label", "label": "Secondary button label", "default": "View Application Overview" },
    { "type": "url", "id": "secondary_link", "label": "Secondary button link" }
  ],
  "blocks": [
    {
      "type": "image_tile",
      "name": "Image tile",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "label", "label": "Label", "default": "Install" },
        { "type": "text", "id": "alt", "label": "Alt text", "default": "BlueTex TermBar install image" }
      ]
    },
    {
      "type": "card",
      "name": "Explainer card",
      "settings": [
        { "type": "text", "id": "step", "label": "Step label", "default": "01 · What It Is" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "What It Is" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "TermBars are aluminum bars that fasten the BlueTex material to the building frame." },
        { "type": "checkbox", "id": "accent", "label": "Use orange top border", "default": false }
      ]
    }
  ],
  "presets": [
    {
      "name": "BlueTex TermBar System",
      "blocks": [
        { "type": "image_tile", "settings": { "label": "Install" } },
        { "type": "image_tile", "settings": { "label": "Finished Look" } },
        { "type": "image_tile", "settings": { "label": "Wall Finish" } },
        { "type": "image_tile", "settings": { "label": "Before" } },
        { "type": "card", "settings": { "step": "01 · What It Is", "heading": "What It Is", "text": "TermBars are aluminum bars that fasten the BlueTex material to the building frame." } },
        { "type": "card", "settings": { "step": "02 · Why It Works", "heading": "Why It Works", "text": "It creates a clean panel look and keeps the material tight against the purlins and girts." } },
        { "type": "card", "settings": { "step": "03 · Why It's Popular", "heading": "Why It's Popular", "text": "Most customers prefer the finished look and strong mechanical attachment.", "accent": true } },
        { "type": "card", "settings": { "step": "04 · Other Options", "heading": "Other Options", "text": "EasyClip and other methods are secondary, used when the building calls for them." } }
      ]
    }
  ]
}
{% endschema %}

<section id="BlueTexProductResources-{{ section.id }}" class="bt-product-resources">
  <div class="bt-product-resources__container">
    <div class="bt-product-resources__label">
      <span>{{ section.settings.heading }}</span>
      {%- if section.settings.link_label != blank -%}<a href="{{ section.settings.link }}">{{ section.settings.link_label }}</a>{%- endif -%}
    </div>
    <div class="bt-product-resources__grid">
      {%- for block in section.blocks -%}
        <a class="bt-product-resources__card" href="{{ block.settings.link }}" {{ block.shopify_attributes }}>
          <span>{{ block.settings.icon }}</span>
          <h3>{{ block.settings.heading }}</h3>
          <p>{{ block.settings.text }}</p>
          <strong>{{ block.settings.cta }}</strong>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  #BlueTexProductResources-{{ section.id }} { --bt-navy:#0011a7; --bt-orange:#ee7f12; --bt-muted:#535254; --bt-soft:#e6e6e7; --bt-grey:#eeeeee; --bt-ink:#1b1b1b; font-family:Lato,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif; background:#fff; padding:40px 0 60px; }
  #BlueTexProductResources-{{ section.id }} * { box-sizing:border-box; }
  #BlueTexProductResources-{{ section.id }} .bt-product-resources__container { max-width:1140px; margin:0 auto; padding:0 20px; }
  #BlueTexProductResources-{{ section.id }} .bt-product-resources__label { background:#e6e6e6; border-left:4px solid var(--bt-navy); padding:14px 22px; display:flex; align-items:center; justify-content:space-between; gap:12px; color:var(--bt-ink); font-size:18px; font-weight:700; letter-spacing:1.4px; line-height:1.2; text-transform:uppercase; }
  #BlueTexProductResources-{{ section.id }} .bt-product-resources__label a { color:var(--bt-navy); font-size:12px; font-weight:700; letter-spacing:.8px; text-decoration:none; white-space:nowrap; }
  #BlueTexProductResources-{{ section.id }} .bt-product-resources__label a:hover { color:var(--bt-orange); }
  #BlueTexProductResources-{{ section.id }} .bt-product-resources__grid { display:grid; grid-template-columns:repeat(4,1fr); gap:14px; margin-top:18px; }
  #BlueTexProductResources-{{ section.id }} .bt-product-resources__card { display:flex; flex-direction:column; min-height:100%; background:#fff; border:1px solid var(--bt-soft); border-radius:2px; padding:22px 20px 24px; text-decoration:none; color:inherit; }
  #BlueTexProductResources-{{ section.id }} .bt-product-resources__card:hover { border-color:var(--bt-navy); box-shadow:0 4px 12px rgba(18,32,92,.1); text-decoration:none; }
  #BlueTexProductResources-{{ section.id }} .bt-product-resources__card > span { width:42px; height:42px; background:var(--bt-grey); color:var(--bt-navy); border-left:3px solid var(--bt-orange); border-radius:2px; display:flex; align-items:center; justify-content:center; font-size:20px; font-weight:700; margin-bottom:12px; }
  #BlueTexProductResources-{{ section.id }} h3 { margin:0 0 6px; color:var(--bt-navy); font-size:14px; line-height:1.25; font-weight:700; letter-spacing:.4px; text-transform:uppercase; }
  #BlueTexProductResources-{{ section.id }} p { margin:0 0 12px; color:var(--bt-muted); font-size:14px; line-height:1.45; flex:1; }
  #BlueTexProductResources-{{ section.id }} strong { color:var(--bt-orange); font-size:11px; font-weight:700; letter-spacing:1.2px; text-transform:uppercase; }
  @media (max-width: 900px) { #BlueTexProductResources-{{ section.id }} .bt-product-resources__grid { grid-template-columns:repeat(2,1fr); } }
  @media (max-width: 560px) { #BlueTexProductResources-{{ section.id }} { padding:32px 0; } #BlueTexProductResources-{{ section.id }} .bt-product-resources__container { padding:0 16px; } #BlueTexProductResources-{{ section.id }} .bt-product-resources__grid { grid-template-columns:1fr; } #BlueTexProductResources-{{ section.id }} .bt-product-resources__label { align-items:flex-start; flex-direction:column; } }
</style>

{% schema %}
{
  "name": "BlueTex Product Resources",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Resources & Support" },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "All Resources →" },
    { "type": "url", "id": "link", "label": "Link" }
  ],
  "blocks": [
    {
      "type": "resource",
      "name": "Resource",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon text", "default": "📐" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Measuring Guide" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Step-by-step measuring for walls, roof, and roll-up doors on a metal building." },
        { "type": "text", "id": "cta", "label": "CTA", "default": "View Guide →" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "BlueTex Product Resources",
      "blocks": [
        { "type": "resource", "settings": { "icon": "📐", "heading": "Measuring Guide", "text": "Step-by-step measuring for walls, roof, and roll-up doors on a metal building.", "cta": "View Guide →" } },
        { "type": "resource", "settings": { "icon": "🔧", "heading": "TermBar Install Guide", "text": "Full TermBar install instructions with photos and tips, using the same method shipped in the sample box.", "cta": "View Install Guide →" } },
        { "type": "resource", "settings": { "icon": "▣", "heading": "Application Overview", "text": "Match your building type to the right BlueTex Cover & Repair system.", "cta": "View Application Overview →" } },
        { "type": "resource", "settings": { "icon": "☑", "heading": "Quote Checklist", "text": "The photos and dimensions we need to put a full-building material list together fast.", "cta": "View Checklist →" } }
      ]
    }
  ]
}
{% endschema %}

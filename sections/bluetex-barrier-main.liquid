{% render 'bluetex-product-main', section: section, product: product %}
{% schema %}
{
  "name": "BlueTex Barrier Main",
  "settings": [
    { "type": "text", "id": "media_badge", "label": "Media badge", "default": "Barrier & Wrap" },
    { "type": "text", "id": "media_placeholder", "label": "Media placeholder", "default": "Barrier media" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Radiant Barrier · Airspace · Wrap" },
    { "type": "text", "id": "fallback_title", "label": "Fallback title", "default": "BlueTex™ Barrier Product" },
    { "type": "textarea", "id": "subheadline", "label": "Subheadline", "default": "Radiant barrier and wrap products for metal building assemblies where foil, airspace, and moisture control need to be understood clearly." },
    { "type": "text", "id": "price_note", "label": "Price note", "default": "Choose based on airspace, vapor control, and building use" },
    { "type": "text", "id": "variant_label", "label": "Variant label", "default": "Option" },
    { "type": "text", "id": "quantity_label", "label": "Quantity label", "default": "Quantity" },
    { "type": "text", "id": "add_to_cart_label", "label": "Add to cart label", "default": "Add Barrier Product to Cart" },
    { "type": "checkbox", "id": "show_dynamic_checkout", "label": "Show dynamic checkout button", "default": true },
    { "type": "text", "id": "quote_label", "label": "Quote button label", "default": "Ask Which Barrier Product Fits" },
    { "type": "url", "id": "quote_link", "label": "Quote button link" }
  ],
  "blocks": [
    { "type": "bullet", "name": "Bullet", "settings": [{ "type": "text", "id": "text", "label": "Text", "default": "Radiant barriers need an airspace to perform as intended." }] },
    { "type": "trust", "name": "Trust block", "settings": [{ "type": "text", "id": "icon", "label": "Icon text", "default": "A" }, { "type": "text", "id": "heading", "label": "Heading", "default": "Airspace Matters" }, { "type": "text", "id": "text", "label": "Text", "default": "Foil needs an adjacent airspace for radiant heat control." }] }
  ],
  "presets": [
    {
      "name": "BlueTex Barrier Main",
      "blocks": [
        { "type": "bullet", "settings": { "text": "Radiant barriers need an airspace to perform as intended." } },
        { "type": "bullet", "settings": { "text": "Perforated radiant barrier is not a vapor barrier." } },
        { "type": "bullet", "settings": { "text": "Thermal Wrap is for fully conditioned buildings where vapor, air, and radiant control matter together." } },
        { "type": "bullet", "settings": { "text": "For cover and repair over old insulation, compare against BlueTex Pro or Supreme rolls." } },
        { "type": "trust", "settings": { "icon": "A", "heading": "Airspace Matters", "text": "Foil needs an adjacent airspace for radiant heat control." } },
        { "type": "trust", "settings": { "icon": "P", "heading": "Perforated", "text": "Lets vapor pass; not a vapor barrier." } },
        { "type": "trust", "settings": { "icon": "V", "heading": "Thermal Wrap", "text": "Vapor barrier, air barrier, and radiant barrier in one path." } },
        { "type": "trust", "settings": { "icon": "Q", "heading": "Quote Support", "text": "Ask for help matching the product to the building." } }
      ]
    }
  ]
}
{% endschema %}

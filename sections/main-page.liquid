{{ 'section-main-page.css' | asset_url | stylesheet_tag }}

{% comment %}
  BTI v13 default page template
  Shared BlueTex shell for standard Shopify pages. Keeps page.title and page.content intact.
{% endcomment %}

{%- liquid
  assign cta_primary_link = section.settings.cta_primary_link | default: '/pages/contact-us'
  assign cta_secondary_link = section.settings.cta_secondary_link | default: '/pages/contact-us'
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="bt-page-shell section-{{ section.id }}-padding">
  <div class="bt-page-hero">
    <div class="bt-page-hero-inner">
      {%- if section.settings.eyebrow != blank -%}
        <span class="bt-page-eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h1 class="bt-page-title main-page-title page-title{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
        {{ page.title | escape }}
      </h1>
      {%- if section.settings.intro_text != blank -%}
        <p class="bt-page-intro">{{ section.settings.intro_text }}</p>
      {%- endif -%}
    </div>
  </div>

  <div class="bt-page-content-wrap">
    <div class="bt-page-content rte{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      {{ page.content }}
    </div>

    {%- if section.settings.show_bottom_cta -%}
      <aside class="bt-page-cta" aria-label="BlueTex help">
        <span class="bt-page-cta__accent"></span>
        <div class="bt-page-cta__copy">
          {%- if section.settings.cta_heading != blank -%}
            <h2>{{ section.settings.cta_heading }}</h2>
          {%- endif -%}
          {%- if section.settings.cta_body != blank -%}
            <p>{{ section.settings.cta_body }}</p>
          {%- endif -%}
        </div>
        <div class="bt-page-cta-actions">
          {%- if section.settings.cta_primary_label != blank -%}
            <a class="bt-page-cta__button" href="{{ cta_primary_link }}">{{ section.settings.cta_primary_label }}</a>
          {%- endif -%}
          {%- if section.settings.cta_secondary_label != blank -%}
            <a class="bt-page-cta__link" href="{{ cta_secondary_link }}">{{ section.settings.cta_secondary_label }}</a>
          {%- endif -%}
        </div>
      </aside>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "t:sections.main-page.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Page header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "BLUETEX GUIDE"
    },
    {
      "type": "textarea",
      "id": "intro_text",
      "label": "Optional intro text"
    },
    {
      "type": "header",
      "content": "Bottom CTA"
    },
    {
      "type": "checkbox",
      "id": "show_bottom_cta",
      "label": "Show bottom CTA",
      "default": true
    },
    {
      "type": "text",
      "id": "cta_heading",
      "label": "CTA heading",
      "default": "Need help choosing the right BlueTex setup?"
    },
    {
      "type": "textarea",
      "id": "cta_body",
      "label": "CTA body",
      "default": "Send us a few photos and rough dimensions. We'll help point you to the right product or quote path."
    },
    {
      "type": "text",
      "id": "cta_primary_label",
      "label": "Primary button label",
      "default": "Request a Quote"
    },
    {
      "type": "url",
      "id": "cta_primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "cta_secondary_label",
      "label": "Secondary link label",
      "default": "What Photos We Need"
    },
    {
      "type": "url",
      "id": "cta_secondary_link",
      "label": "Secondary link"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ]
}
{% endschema %}

{%- liquid
  assign section_eyebrow = section.settings.eyebrow
  assign section_heading = section.settings.heading
  assign section_text = section.settings.text
-%}

<section class="btx-apps"{% if section.settings.anchor_id != blank %} id="{{ section.settings.anchor_id | handleize }}"{% endif %}>
  <div class="btx-apps__inner">
    {%- if section_eyebrow != blank or section_heading != blank or section_text != blank -%}
      <header class="btx-apps__head">
        {%- if section_eyebrow != blank -%}
          <span class="btx-apps__eyebrow">{{ section_eyebrow | escape }}</span>
        {%- endif -%}
        {%- if section_heading != blank -%}
          <h2 class="btx-apps__heading">{{ section_heading | escape }}</h2>
        {%- endif -%}
        {%- if section_text != blank -%}
          <div class="btx-apps__text">{{ section_text }}</div>
        {%- endif -%}
      </header>
    {%- endif -%}

    <div class="btx-apps__grid">
      {%- for block in section.blocks -%}
        <article class="btx-app-card" {{ block.shopify_attributes }}>
          <div class="btx-app-card__media">
            {%- if block.settings.image != blank -%}
              {{
                block.settings.image
                | image_url: width: 1200
                | image_tag:
                  loading: 'lazy',
                  widths: '480, 720, 960, 1200',
                  sizes: '(min-width: 750px) 50vw, 100vw',
                  alt: block.settings.image_alt | default: block.settings.title
              }}
            {%- else -%}
              <span class="btx-app-card__placeholder" aria-hidden="true">
                {{ block.settings.image_alt | default: block.settings.title | default: 'Image' | escape }}
              </span>
            {%- endif -%}
          </div>
          <div class="btx-app-card__body">
            {%- if block.settings.title != blank -%}
              <h3 class="btx-app-card__title">{{ block.settings.title | escape }}</h3>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <div class="btx-app-card__text">{{ block.settings.text }}</div>
            {%- endif -%}
            {%- if block.settings.primary_label != blank or block.settings.secondary_label != blank -%}
              <div class="btx-app-card__buttons">
                {%- if block.settings.primary_label != blank and block.settings.primary_url != blank -%}
                  <a class="btx-btn btx-btn--navy" href="{{ block.settings.primary_url }}">{{ block.settings.primary_label | escape }}</a>
                {%- endif -%}
                {%- if block.settings.secondary_label != blank and block.settings.secondary_url != blank -%}
                  <a class="btx-btn btx-btn--outline" href="{{ block.settings.secondary_url }}">{{ block.settings.secondary_label | escape }}</a>
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "BTX application grid",
  "settings": [
    { "type": "text", "id": "anchor_id", "label": "Optional anchor ID" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Two More Ways We Help" },
    { "type": "richtext", "id": "text", "label": "Intro text" }
  ],
  "blocks": [
    {
      "type": "application",
      "name": "Application card",
      "limit": 2,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "image_alt", "label": "Image alt text" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "richtext", "id": "text", "label": "Text" },
        { "type": "text", "id": "primary_label", "label": "Primary button label" },
        { "type": "url", "id": "primary_url", "label": "Primary button link" },
        { "type": "text", "id": "secondary_label", "label": "Secondary button label" },
        { "type": "url", "id": "secondary_url", "label": "Secondary button link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "BTX application grid",
      "blocks": [
        { "type": "application" },
        { "type": "application" }
      ]
    }
  ]
}
{% endschema %}

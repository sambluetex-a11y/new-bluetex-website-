<section class="bti-section{% if section.settings.use_soft_background %} bti-section--soft{% endif %}"{% if section.settings.anchor_id != blank %} id="{{ section.settings.anchor_id | handleize }}"{% endif %}>
  <div class="bti-container bti-stack">
    {%- render 'bti-section-heading',
      eyebrow: section.settings.eyebrow,
      heading: section.settings.heading,
      text: section.settings.text,
      align: section.settings.heading_align,
      heading_size: 'medium'
    -%}
    <div class="bti-grid bti-grid--two">
      {%- for block in section.blocks -%}
        {%- render 'bti-media-card',
          image: block.settings.image,
          image_alt: block.settings.image_alt,
          title: block.settings.title,
          text: block.settings.text,
          primary_label: block.settings.primary_label,
          primary_url: block.settings.primary_url,
          secondary_label: block.settings.secondary_label,
          secondary_url: block.settings.secondary_url
        -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "BTI application grid",
  "settings": [
    { "type": "checkbox", "id": "use_soft_background", "label": "Use soft background", "default": false },
    { "type": "text", "id": "anchor_id", "label": "Optional anchor ID" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Popular applications" },
    { "type": "richtext", "id": "text", "label": "Text" },
    {
      "type": "select",
      "id": "heading_align",
      "label": "Heading alignment",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ]
    }
  ],
  "blocks": [
    {
      "type": "application",
      "name": "Application card",
      "limit": 2,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "image_alt", "label": "Image alt text" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "richtext", "id": "text", "label": "Text" },
        { "type": "text", "id": "primary_label", "label": "Primary button label" },
        { "type": "url", "id": "primary_url", "label": "Primary button link" },
        { "type": "text", "id": "secondary_label", "label": "Secondary button label" },
        { "type": "url", "id": "secondary_url", "label": "Secondary button link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "BTI application grid",
      "blocks": [
        { "type": "application" },
        { "type": "application" }
      ]
    }
  ]
}
{% endschema %}

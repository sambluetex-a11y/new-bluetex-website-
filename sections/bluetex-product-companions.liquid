{{ 'bluetex-product-templates.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign band_class = 'btp__band'
  if section.settings.background == 'grey'
    assign band_class = 'btp__band btp__band--grey'
  endif
-%}

<section id="BlueTexCompanions-{{ section.id }}" class="btp {{ band_class }}">
  <div class="btp__container">
    <div class="btp__label">
      <span>{{ section.settings.heading }}</span>
      {%- if section.settings.link_label != blank -%}<a href="{{ section.settings.link }}">{{ section.settings.link_label }}</a>{%- endif -%}
    </div>
    {%- if section.settings.text != blank -%}<p class="btp__intro">{{ section.settings.text }}</p>{%- endif -%}
    <div class="btp-companions__grid">
      {%- for block in section.blocks limit: 5 -%}
        {%- liquid
          assign companion = block.settings.product
          assign card_title = block.settings.heading
          assign card_link = block.settings.link
          if companion != blank
            if card_title == blank
              assign card_title = companion.title
            endif
            if card_link == blank
              assign card_link = companion.url
            endif
          endif
        -%}
        <article class="btp-companion" {{ block.shopify_attributes }}>
          <h3>{{ card_title }}</h3>
          <p>{{ block.settings.text }}</p>
          {%- if block.settings.cta_label != blank and card_link != blank -%}<a href="{{ card_link }}">{{ block.settings.cta_label }}</a>{%- endif -%}
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "BlueTex Product Companion",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Complete the System" },
    { "type": "textarea", "id": "text", "label": "Intro text", "default": "These are the parts customers commonly pair with this product." },
    { "type": "select", "id": "background", "label": "Background", "options": [{ "value": "white", "label": "White" }, { "value": "grey", "label": "Light gray" }], "default": "white" },
    { "type": "text", "id": "link_label", "label": "Link label" },
    { "type": "url", "id": "link", "label": "Link" }
  ],
  "blocks": [
    {
      "type": "companion",
      "name": "Companion",
      "settings": [
        { "type": "product", "id": "product", "label": "Product" },
        { "type": "text", "id": "heading", "label": "Fallback/category name", "default": "3\" White Vapor Barrier Seam Tape" },
        { "type": "textarea", "id": "text", "label": "Why it goes with this", "default": "Seals seams after the BlueTex material is fastened." },
        { "type": "text", "id": "cta_label", "label": "CTA label", "default": "View Product" },
        { "type": "url", "id": "link", "label": "Fallback link" }
      ]
    }
  ],
  "presets": [{ "name": "BlueTex Product Companion" }]
}
{% endschema %}

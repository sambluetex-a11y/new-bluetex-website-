<section id="BlueTexRedeemBand-{{ section.id }}" class="bt-redeem-band">
  <div class="bt-redeem-band__inner">
    <div class="bt-redeem-band__badge">{{ section.settings.badge }}</div>
    <div>
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.text }}</p>
    </div>
    {%- if section.settings.button_label != blank -%}
      <a class="bt-redeem-band__btn" href="{{ section.settings.button_link }}">{{ section.settings.button_label }}</a>
    {%- endif -%}
  </div>
  {%- if section.settings.fine_print != blank -%}
    <p class="bt-redeem-band__fine">{{ section.settings.fine_print }}</p>
  {%- endif -%}
</section>

<style>
  #BlueTexRedeemBand-{{ section.id }} { --bt-deep:#002f6c; --bt-orange:#ee7f12; --bt-orange-hov:#3f62c5; font-family:Lato,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif; background:var(--bt-deep); color:#fff; padding:46px 0; }
  #BlueTexRedeemBand-{{ section.id }} * { box-sizing:border-box; }
  #BlueTexRedeemBand-{{ section.id }} .bt-redeem-band__inner { max-width:1140px; margin:0 auto; padding:0 20px; display:grid; grid-template-columns:auto 1fr auto; gap:28px; align-items:center; }
  #BlueTexRedeemBand-{{ section.id }} .bt-redeem-band__badge { width:84px; height:84px; border-radius:6px; background:var(--bt-orange); border:3px solid #fff; display:flex; align-items:center; justify-content:center; text-align:center; color:#fff; font-size:13px; font-weight:700; letter-spacing:.6px; line-height:1.05; text-transform:uppercase; white-space:pre-line; }
  #BlueTexRedeemBand-{{ section.id }} h2 { margin:0 0 8px; color:#fff; font-size:24px; font-weight:700; line-height:1.12; letter-spacing:.2px; text-transform:uppercase; }
  #BlueTexRedeemBand-{{ section.id }} p { margin:0; color:#dfe3f0; font-size:15px; line-height:1.55; }
  #BlueTexRedeemBand-{{ section.id }} .bt-redeem-band__btn { display:inline-flex; align-items:center; justify-content:center; padding:16px 28px; border-radius:4px; border:2px solid #fff; background:#fff; color:var(--bt-deep); text-decoration:none; font-size:14px; font-weight:700; letter-spacing:.8px; text-transform:uppercase; white-space:nowrap; }
  #BlueTexRedeemBand-{{ section.id }} .bt-redeem-band__btn:hover { background:#eeeeee; border-color:#eeeeee; color:var(--bt-deep); }
  #BlueTexRedeemBand-{{ section.id }} .bt-redeem-band__fine { max-width:1140px; margin:14px auto 0; padding:0 20px; color:#9aa3c2; font-size:12px; line-height:1.55; }
  @media (max-width: 900px) { #BlueTexRedeemBand-{{ section.id }} .bt-redeem-band__inner { grid-template-columns:auto 1fr; } #BlueTexRedeemBand-{{ section.id }} .bt-redeem-band__btn { grid-column:1 / -1; justify-self:start; } }
  @media (max-width: 560px) { #BlueTexRedeemBand-{{ section.id }} { padding:34px 0; } #BlueTexRedeemBand-{{ section.id }} .bt-redeem-band__inner, #BlueTexRedeemBand-{{ section.id }} .bt-redeem-band__fine { padding:0 16px; } #BlueTexRedeemBand-{{ section.id }} .bt-redeem-band__inner { grid-template-columns:1fr; } }
</style>

{% schema %}
{
  "name": "BlueTex Redeem Band",
  "settings": [
    { "type": "text", "id": "badge", "label": "Badge", "default": "$100\nCredit" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The $100 You Spend Comes Right Back" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "The purchase price of this kit is fully redeemable toward any future order of $500 or more, so the kit can essentially be free to try. Place the second order and we'll apply the $100 to your new order." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Order the Sample Box" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "textarea", "id": "fine_print", "label": "Fine print", "default": "Buying multiple sample boxes? Each box is redeemable per $500 of your follow-on order. Two boxes credit $200 on a $1,000 order ($100 credit per $500 purchased). Call 1-800-595-8772 to apply your credit." }
  ],
  "presets": [
    { "name": "BlueTex Redeem Band" }
  ]
}
{% endschema %}

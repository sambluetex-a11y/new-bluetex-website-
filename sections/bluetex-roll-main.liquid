{% render 'bluetex-product-main', section: section, product: product %}
{% schema %}
{
  "name": "BlueTex Roll Main",
  "settings": [
    { "type": "text", "id": "media_badge", "label": "Media badge", "default": "BlueTex Roll" },
    { "type": "text", "id": "media_placeholder", "label": "Media placeholder", "default": "Product media" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Metal Building Cover & Repair Roll" },
    { "type": "text", "id": "fallback_title", "label": "Fallback title", "default": "BlueTex™ Insulation Roll" },
    { "type": "textarea", "id": "subheadline", "label": "Subheadline", "default": "BlueTex roll insulation for covering, repairing, and finishing metal building interiors with a clean foil/white system." },
    { "type": "text", "id": "price_note", "label": "Price note", "default": "Quote full-building projects from photos and dimensions" },
    { "type": "text", "id": "variant_label", "label": "Variant label", "default": "Roll option" },
    { "type": "text", "id": "quantity_label", "label": "Quantity label", "default": "Quantity" },
    { "type": "text", "id": "add_to_cart_label", "label": "Add to cart label", "default": "Add Roll to Cart" },
    { "type": "checkbox", "id": "show_dynamic_checkout", "label": "Show dynamic checkout button", "default": true },
    { "type": "text", "id": "quote_label", "label": "Quote button label", "default": "Send Photos for a Full-Building Quote" },
    { "type": "url", "id": "quote_link", "label": "Quote button link" }
  ],
  "blocks": [
    { "type": "bullet", "name": "Bullet", "settings": [{ "type": "text", "id": "text", "label": "Text", "default": "Foil side reflects radiant heat; white side creates a clean finished interior surface." }] },
    { "type": "trust", "name": "Trust block", "settings": [{ "type": "text", "id": "icon", "label": "Icon text", "default": "✓" }, { "type": "text", "id": "heading", "label": "Heading", "default": "Metal Building Focus" }, { "type": "text", "id": "text", "label": "Text", "default": "Built around cover, repair, and retrofit insulation projects." }] }
  ],
  "presets": [
    {
      "name": "BlueTex Roll Main",
      "blocks": [
        { "type": "bullet", "settings": { "text": "Foil side reflects radiant heat; white side creates a clean finished interior surface." } },
        { "type": "bullet", "settings": { "text": "50-inch rolls are the preferred width for most cover and repair work when the product is available in that width." } },
        { "type": "bullet", "settings": { "text": "Use TermBars, white vapor barrier seam tape, and fasteners to build the full BlueTex system." } },
        { "type": "bullet", "settings": { "text": "Send photos and dimensions for a full-building material list before ordering large projects." } },
        { "type": "trust", "settings": { "icon": "2", "heading": "2mm Pro", "text": "Lean cover and repair layer for common retrofit projects." } },
        { "type": "trust", "settings": { "icon": "6", "heading": "6mm Supreme", "text": "Thicker foam layer for projects needing more body and insulation value." } },
        { "type": "trust", "settings": { "icon": "T", "heading": "TermBar System", "text": "Mechanical fastening keeps the finished surface tight to the frame." } },
        { "type": "trust", "settings": { "icon": "Q", "heading": "Quote Support", "text": "Photos and dimensions help us size rolls, TermBars, tape, and fasteners." } }
      ]
    }
  ]
}
{% endschema %}

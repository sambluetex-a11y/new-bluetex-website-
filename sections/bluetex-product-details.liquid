{{ 'bluetex-product-templates.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign band_class = 'btp__band'
  if section.settings.background == 'grey'
    assign band_class = 'btp__band btp__band--grey'
  endif
-%}

<section id="BlueTexDetails-{{ section.id }}" class="btp {{ band_class }}">
  <div class="btp__container">
    <div class="btp__label"><span>{{ section.settings.heading }}</span></div>
    {%- if section.settings.text != blank -%}<p class="btp__intro">{{ section.settings.text }}</p>{%- endif -%}
    <div class="btp-details">
      {%- for block in section.blocks -%}
        <details {% if forloop.first and section.settings.open_first %}open{% endif %} {{ block.shopify_attributes }}>
          <summary>{{ block.settings.heading }}</summary>
          <div class="btp-details__body">{{ block.settings.text }}</div>
        </details>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "BlueTex Product Details",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Details" },
    { "type": "textarea", "id": "text", "label": "Intro text", "default": "Open the details below for specs, install notes, and common questions." },
    { "type": "select", "id": "background", "label": "Background", "options": [{ "value": "white", "label": "White" }, { "value": "grey", "label": "Light gray" }], "default": "grey" },
    { "type": "checkbox", "id": "open_first", "label": "Open first item", "default": false }
  ],
  "blocks": [
    {
      "type": "detail",
      "name": "Detail",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Full description" },
        { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Add product details, specs, install notes, or FAQ content here.</p>" }
      ]
    }
  ],
  "presets": [{ "name": "BlueTex Product Details" }]
}
{% endschema %}

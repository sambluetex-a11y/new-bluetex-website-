        "card_works": {
          "type": "card",
          "settings": {
            "step": "02 · Why It Works",
            "heading": "Why It Works",
            "text": "It creates a clean panel look and keeps the material tight against the purlins and girts.",
            "accent": false
          }
        },
        "card_popular": {
          "type": "card",
          "settings": {
            "step": "03 · Why It's Popular",
            "heading": "Why It's Popular",
            "text": "Most customers prefer the finished look and strong mechanical attachment.",

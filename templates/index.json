    "bluetex_faq": {
      "type": "bluetex-faq",
      "blocks": {
        "strong": {
          "type": "question",
          "settings": {
            "question": "Is It Strong?",
            "answer": "Yes. TermBars mechanically fasten the material to the building frame. The finished wall is tighter and more durable than the original metal building insulation it covers.",
            "featured": true
          }
        },
        "paint": {
          "type": "question",
          "settings": {
            "question": "Can You Paint It?",
            "answer": "Yes. BlueTex and the TermBars both hold paint. Most customers leave it bright white for light reflection, but you can roll or spray latex paint for a custom color.",
            "featured": false
          }
        },
        "tearout": {
          "type": "question",
          "settings": {
            "question": "Do I Have to Tear Out the Old Insulation?",
            "answer": "Usually no. BlueTex is commonly installed over existing insulation. The TermBar presses the old material in place and the new BlueTex creates the finished interior.",
            "featured": false
          }
        }
      },
      "block_order": [
        "strong",
        "paint",
        "tearout"
      ],

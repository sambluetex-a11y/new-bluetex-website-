<section style="padding:48px 0;background:#fff;">
  <div class="container">
    <h1 style="color:var(--navy);font-size:32px;margin-bottom:24px;">{{ blog.title }}</h1>
    <div style="display:grid;gap:16px;max-width:780px;">
      {%- for article in blog.articles -%}
        <a href="{{ article.url }}" style="border:1px solid var(--line-soft);border-left:4px solid var(--orange);padding:18px 22px;display:block;text-decoration:none;background:#fff;border-radius:2px;">
          <h3 style="color:var(--navy);margin:0 0 6px;font-size:18px;">{{ article.title }}</h3>
          <div style="color:var(--muted);font-size:13px;">{{ article.published_at | date: '%B %-d, %Y' }}</div>
          {%- if article.excerpt != blank -%}
            <p style="margin:10px 0 0;color:var(--text);font-size:14px;text-transform:none;">{{ article.excerpt | strip_html | truncate: 200 }}</p>
          {%- endif -%}
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

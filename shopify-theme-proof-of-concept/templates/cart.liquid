<section style="padding:48px 0;background:#fff;">
  <div class="container">
    <h1 style="color:var(--navy);font-size:28px;margin-bottom:20px;">Your Cart</h1>

    {%- if cart.item_count > 0 -%}
      {%- form 'cart', cart -%}
        <table style="width:100%;border-collapse:collapse;font-size:14px;">
          <thead>
            <tr style="border-bottom:2px solid var(--line);text-align:left;text-transform:uppercase;font-size:12px;letter-spacing:1px;color:var(--muted);">
              <th style="padding:12px 0;">Product</th>
              <th style="padding:12px 0;">Qty</th>
              <th style="padding:12px 0;text-align:right;">Total</th>
            </tr>
          </thead>
          <tbody>
            {%- for item in cart.items -%}
              <tr style="border-bottom:1px solid var(--line-soft);">
                <td style="padding:14px 0;">
                  <a href="{{ item.url }}" style="color:var(--ink);font-weight:700;">{{ item.product.title }}</a>
                  {%- if item.variant.title != 'Default Title' -%}<div style="color:var(--muted);font-size:12px;">{{ item.variant.title }}</div>{%- endif -%}
                </td>
                <td style="padding:14px 0;">
                  <input type="number" name="updates[]" value="{{ item.quantity }}" min="0" style="width:60px;padding:6px 8px;border:2px solid var(--line);border-radius:2px;">
                </td>
                <td style="padding:14px 0;text-align:right;font-weight:700;">{{ item.line_price | money }}</td>
              </tr>
            {%- endfor -%}
          </tbody>
        </table>

        <div style="display:flex;justify-content:space-between;align-items:center;margin-top:24px;gap:16px;flex-wrap:wrap;">
          <button type="submit" name="update" class="btn btn--outline">Update Cart</button>
          <div style="text-align:right;">
            <div style="font-size:14px;color:var(--muted);text-transform:uppercase;letter-spacing:1px;">Subtotal</div>
            <div style="font-size:24px;font-weight:900;color:var(--ink);">{{ cart.total_price | money }}</div>
          </div>
        </div>

        <div style="margin-top:18px;text-align:right;">
          <button type="submit" name="checkout" class="btn btn--orange btn--lg">Check Out</button>
        </div>
      {%- endform -%}
    {%- else -%}
      <p>Your cart is empty.</p>
      <a href="{{ routes.root_url }}" class="btn btn--navy">Continue Browsing</a>
    {%- endif -%}
  </div>
</section>

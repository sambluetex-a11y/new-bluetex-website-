{%- comment -%}
  Default product template (fallback for products that are NOT the sample box).
  The sample box product uses templates/product.sample-box.json.
  This stub is intentionally minimal — refine in production build.
{%- endcomment -%}

<section class="pdp-wrap">
  <div class="pdp-grid">
    <div class="pdp-gallery">
      <div class="gal-main">
        {%- if product.featured_image != blank -%}
          <img src="{{ product.featured_image | image_url: width: 1000 }}" alt="{{ product.title | escape }}">
        {%- endif -%}
      </div>
    </div>

    <div class="pdp-buy">
      <h1 class="pdp-title">{{ product.title }}</h1>
      <div class="pdp-price-row">
        <div class="pdp-price">{{ product.price | money }}</div>
      </div>

      {%- if product.description != blank -%}
        <div class="pdp-sub">{{ product.description }}</div>
      {%- endif -%}

      {%- form 'product', product -%}
        {%- assign current_variant = product.selected_or_first_available_variant -%}
        <input type="hidden" name="id" value="{{ current_variant.id }}">
        <div class="qty-row">
          <span class="qty-label">{{ 'products.product.quantity' | t }}</span>
          <div class="qty" data-qty>
            <button type="button" data-qty-dec aria-label="Decrease">−</button>
            <input type="text" name="quantity" value="1" inputmode="numeric">
            <button type="button" data-qty-inc aria-label="Increase">+</button>
          </div>
        </div>
        <div class="pdp-cta-stack">
          <button type="submit" class="btn btn--orange btn--lg btn--block" {% unless current_variant.available %}disabled{% endunless %}>
            {%- if current_variant.available -%}{{ 'products.product.add_to_cart' | t }}{%- else -%}{{ 'products.product.sold_out' | t }}{%- endif -%}
          </button>
        </div>
      {%- endform -%}
    </div>
  </div>
</section>

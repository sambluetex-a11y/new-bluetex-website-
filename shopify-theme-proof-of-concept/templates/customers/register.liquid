<section style="padding:60px 0;background:#fff;">
  <div class="container" style="max-width:480px;">
    <h1 style="color:var(--navy);font-size:28px;margin-bottom:18px;">Create Account</h1>

    {%- form 'create_customer' -%}
      {%- if form.errors -%}
        <div style="color:#c0392b;margin-bottom:14px;font-size:13px;">{{ form.errors | default_errors }}</div>
      {%- endif -%}

      <label style="display:block;font-size:12px;font-weight:700;text-transform:uppercase;color:var(--ink);margin-bottom:6px;">First Name</label>
      <input type="text" name="customer[first_name]" style="width:100%;padding:10px 12px;border:2px solid var(--line);margin-bottom:14px;border-radius:2px;">

      <label style="display:block;font-size:12px;font-weight:700;text-transform:uppercase;color:var(--ink);margin-bottom:6px;">Last Name</label>
      <input type="text" name="customer[last_name]" style="width:100%;padding:10px 12px;border:2px solid var(--line);margin-bottom:14px;border-radius:2px;">

      <label style="display:block;font-size:12px;font-weight:700;text-transform:uppercase;color:var(--ink);margin-bottom:6px;">Email</label>
      <input type="email" name="customer[email]" required style="width:100%;padding:10px 12px;border:2px solid var(--line);margin-bottom:14px;border-radius:2px;">

      <label style="display:block;font-size:12px;font-weight:700;text-transform:uppercase;color:var(--ink);margin-bottom:6px;">Password</label>
      <input type="password" name="customer[password]" required style="width:100%;padding:10px 12px;border:2px solid var(--line);margin-bottom:14px;border-radius:2px;">

      <button type="submit" class="btn btn--orange btn--lg btn--block">Create Account</button>
    {%- endform -%}

    <div style="margin-top:18px;font-size:13px;"><a href="{{ routes.account_login_url }}">Already have an account? Sign in</a></div>
  </div>
</section>

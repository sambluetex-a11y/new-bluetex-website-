<section style="padding:60px 0;background:#fff;">
  <div class="container" style="max-width:480px;">
    <h1 style="color:var(--navy);font-size:28px;margin-bottom:8px;">Activate Your Account</h1>
    <p style="color:var(--muted);margin-bottom:18px;">Set a password to finish creating your account.</p>

    {%- form 'activate_customer_password' -%}
      {%- if form.errors -%}
        <div style="color:#c0392b;margin-bottom:14px;font-size:13px;">{{ form.errors | default_errors }}</div>
      {%- endif -%}

      <label style="display:block;font-size:12px;font-weight:700;text-transform:uppercase;color:var(--ink);margin-bottom:6px;">Password</label>
      <input type="password" name="customer[password]" required style="width:100%;padding:10px 12px;border:2px solid var(--line);margin-bottom:14px;border-radius:2px;">

      <label style="display:block;font-size:12px;font-weight:700;text-transform:uppercase;color:var(--ink);margin-bottom:6px;">Confirm Password</label>
      <input type="password" name="customer[password_confirmation]" required style="width:100%;padding:10px 12px;border:2px solid var(--line);margin-bottom:14px;border-radius:2px;">

      <button type="submit" class="btn btn--orange btn--lg btn--block">Activate Account</button>
    {%- endform -%}
  </div>
</section>

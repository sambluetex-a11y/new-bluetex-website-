{% layout none %}
<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{{ 'gift_cards.issued.title' | t: value: gift_card.balance | money, shop: shop.name }}</title>
  {{ 'theme.css' | asset_url | stylesheet_tag }}
</head>
<body style="background:var(--bg-grey);padding:60px 20px;font-family:var(--fs);">
  <div style="max-width:540px;margin:0 auto;background:#fff;border:1px solid var(--line);border-radius:6px;padding:36px;text-align:center;">
    <h1 style="color:var(--navy);font-size:24px;margin-bottom:8px;">{{ shop.name }} Gift Card</h1>
    <p style="color:var(--muted);margin-bottom:24px;">Use this code at checkout.</p>

    <div style="font-size:36px;font-weight:900;color:var(--ink);margin-bottom:18px;">{{ gift_card.balance | money }}</div>

    <div style="background:var(--bg-grey);padding:14px;border-radius:4px;font-family:monospace;font-size:18px;letter-spacing:2px;color:var(--ink);">
      {{ gift_card.code | format_code }}
    </div>

    {%- if gift_card.expired -%}
      <p style="color:#c0392b;margin-top:18px;">{{ 'gift_cards.issued.expired' | t }}</p>
    {%- endif -%}

    <a href="{{ shop.url }}" style="display:inline-block;margin-top:24px;color:var(--navy);font-weight:700;text-transform:uppercase;letter-spacing:1px;font-size:13px;">{{ 'gift_cards.issued.shop_link' | t }}</a>
  </div>
</body>
</html>

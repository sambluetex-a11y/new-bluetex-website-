<section style="padding:80px 0;background:#fff;text-align:center;min-height:60vh;">
  <div class="container" style="max-width:520px;">
    {%- if shop.password_message != blank -%}
      <p style="color:var(--text);margin-bottom:24px;">{{ shop.password_message }}</p>
    {%- endif -%}
    <h1 style="color:var(--navy);font-size:28px;margin-bottom:18px;">{{ shop.name }}</h1>
    <p style="color:var(--muted);margin-bottom:24px;">Opening soon. Enter the store password to continue.</p>

    {%- form 'storefront_password' -%}
      <input type="password" name="password" placeholder="Password" style="padding:12px 16px;border:2px solid var(--line);border-radius:2px;font-size:15px;width:260px;">
      <button type="submit" class="btn btn--orange">Enter</button>
      {%- if form.errors -%}
        <div style="color:#c0392b;margin-top:12px;font-size:13px;">{{ form.errors | default_errors }}</div>
      {%- endif -%}
    {%- endform -%}
  </div>
</section>

{% comment %}
  BlueTex Quote CTA
  Navy band with orange left accent. Heading + paragraph + two buttons.
{% endcomment %}

<section class="quote-wrap">
  <div class="container">
    <div class="quote-inner">
      <div>
        <h2>{{ section.settings.heading }}</h2>
        {%- if section.settings.body != blank -%}
          <p>{{ section.settings.body }}</p>
        {%- endif -%}
      </div>
      <div class="btn-row">
        {%- if section.settings.cta1_label != blank -%}
          <a href="{{ section.settings.cta1_url }}" class="btn btn--orange btn--lg">{{ section.settings.cta1_label }}</a>
        {%- endif -%}
        {%- if section.settings.cta2_label != blank -%}
          <a href="{{ section.settings.cta2_url }}" class="btn btn--white btn--lg">{{ section.settings.cta2_label }}</a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Quote CTA",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Send Photos and Dimensions for a Quote" },
    { "type": "textarea", "id": "body", "label": "Body", "default": "We put together a material list faster when we can see your building. Simple quote for a budget number, complete quote for a full line-item list." },
    { "type": "text", "id": "cta1_label", "label": "Primary CTA label", "default": "Request a Quote" },
    { "type": "url", "id": "cta1_url", "label": "Primary CTA URL" },
    { "type": "text", "id": "cta2_label", "label": "Secondary CTA label", "default": "Send Photos for a Quote" },
    { "type": "url", "id": "cta2_url", "label": "Secondary CTA URL" }
  ],
  "presets": [
    { "name": "Quote CTA" }
  ]
}
{% endschema %}

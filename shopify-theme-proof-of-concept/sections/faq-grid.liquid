{% comment %}
  BlueTex FAQ Grid
  Label-bar heading + grid of FAQ cards (each FAQ is a block).
{% endcomment %}

<section class="faq-wrap">
  <div class="container">
    <div class="label-bar">
      {{ section.settings.heading }}
      {%- if section.settings.link_label != blank and section.settings.link_url != blank -%}
        <a href="{{ section.settings.link_url }}">{{ section.settings.link_label }} →</a>
      {%- endif -%}
    </div>
    <div class="faq-grid">
      {%- for block in section.blocks -%}
        <div class="faq-card" {{ block.shopify_attributes }}>
          <h3 class="faq-q">{{ block.settings.question }}</h3>
          <p class="faq-a">{{ block.settings.answer }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ grid",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Common Questions" },
    { "type": "text", "id": "link_label", "label": "Side link label", "default": "View Full FAQ" },
    { "type": "url", "id": "link_url", "label": "Side link URL" }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "Is It Strong?" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>Yes. TermBars mechanically fasten the material to the building frame.</p>" }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "FAQ grid",
      "blocks": [
        { "type": "faq" },
        { "type": "faq" },
        { "type": "faq" }
      ]
    }
  ]
}
{% endschema %}

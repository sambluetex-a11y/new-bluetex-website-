{% comment %}
  BlueTex $100 Redeemable Band
  Navy-deep band with orange medal, heading, body, CTA, and fine print.
{% endcomment %}

<section class="redeem-wrap">
  <div class="redeem">
    <div class="redeem-medal">{{ section.settings.medal_text }}</div>
    <div>
      <h2>{{ section.settings.heading }}</h2>
      {%- if section.settings.body != blank -%}
        <p>{{ section.settings.body }}</p>
      {%- endif -%}
    </div>
    {%- if section.settings.cta_label != blank -%}
      <div class="btn-row">
        <a href="{{ section.settings.cta_url }}" class="btn btn--orange btn--lg">{{ section.settings.cta_label }}</a>
      </div>
    {%- endif -%}
  </div>
  {%- if section.settings.fine_print != blank -%}
    <div class="redeem-fine">{{ section.settings.fine_print }}</div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Redeemable band",
  "settings": [
    { "type": "text", "id": "medal_text", "label": "Medal text", "default": "$100 Credit" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The $100 You Spend Comes Right Back" },
    { "type": "textarea", "id": "body", "label": "Body", "default": "The purchase price of this kit is fully redeemable toward any future order of $500 or more — so the kit can essentially be free to try. Place the second order and we'll apply the $100 to your new order." },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Order the Sample Box" },
    { "type": "url", "id": "cta_url", "label": "CTA URL" },
    { "type": "richtext", "id": "fine_print", "label": "Fine print", "default": "<p>Buying multiple sample boxes? Each box is redeemable per $500 of your follow-on order.</p>" }
  ],
  "presets": [
    { "name": "Redeemable band" }
  ]
}
{% endschema %}

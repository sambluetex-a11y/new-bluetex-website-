{% comment %}
  BlueTex Footer
  Brand block + four linklist columns. Each column is a block so the
  merchant can add/remove columns and pick which menu drives each.
{% endcomment %}

<footer class="footer">
  <div class="footer-grid">
    <div class="footer-brand">
      {%- if settings.logo_white != blank -%}
        {{ settings.logo_white | image_url: width: 320 | image_tag: alt: shop.name }}
      {%- elsif settings.logo != blank -%}
        {{ settings.logo | image_url: width: 320 | image_tag: alt: shop.name }}
      {%- endif -%}
      {%- if section.settings.tagline != blank -%}
        <p>{{ section.settings.tagline }}</p>
      {%- endif -%}
      <div class="footer-contact">
        {%- if settings.phone != blank -%}
          <strong>{{ settings.phone }}</strong>
        {%- endif -%}
        {{ settings.address | newline_to_br }}
      </div>
    </div>

    {%- for block in section.blocks -%}
      <div {{ block.shopify_attributes }}>
        <h4>{{ block.settings.heading }}</h4>
        <ul>
          {%- for link in block.settings.menu.links -%}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {%- endfor -%}
        </ul>
      </div>
    {%- endfor -%}
  </div>

  <div class="footer-bottom">
    <div>© {{ 'now' | date: '%Y' }} {{ shop.name }} · All rights reserved</div>
    <div>
      {%- if section.settings.privacy_url != blank -%}<a href="{{ section.settings.privacy_url }}">Privacy</a> · {%- endif -%}
      {%- if section.settings.terms_url != blank -%}<a href="{{ section.settings.terms_url }}">Terms</a>{%- endif -%}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "Brand tagline",
      "default": "Cover, repair, and retrofit insulation systems for metal buildings. Practical products, real installs, quote-based service."
    },
    {
      "type": "url",
      "id": "privacy_url",
      "label": "Privacy policy URL"
    },
    {
      "type": "url",
      "id": "terms_url",
      "label": "Terms URL"
    }
  ],
  "blocks": [
    {
      "type": "menu_column",
      "name": "Menu column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Systems"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "default": {
    "blocks": [
      { "type": "menu_column", "settings": { "heading": "Systems" } },
      { "type": "menu_column", "settings": { "heading": "Resources" } },
      { "type": "menu_column", "settings": { "heading": "Company" } },
      { "type": "menu_column", "settings": { "heading": "Get Started" } }
    ]
  }
}
{% endschema %}
